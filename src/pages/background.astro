---
import DefaultLayout from "@layouts/DefaultLayout.astro";
import SplashScreen from "@components/SplashScreen.astro";
import HeroSection from "@components/HeroSection.astro";
import KataSambutan from "@components/KataSambutan.astro";
import EventDetails from "@components/EventDetails.astro";
import Twibbon from "@components/Twibbon.astro";
import AbsensiSection from "@components/AbsensiSection.astro";
import UcapanDoa from "@components/UcapanDoa.astro";
import Footer from "@components/Footer.astro";
import "croppie/croppie.css";
---

<DefaultLayout>
  <SplashScreen useBg={true} />

  <HeroSection useBg={true} />

  <KataSambutan useBg={true} />

  <EventDetails useBg={true} />

  <AbsensiSection useBg={true} />

  <Twibbon useBg={true} />

  <UcapanDoa useBg={true} />

  <Footer />
