---
interface Props {
  welcome: string;
  tagline: string;
  subtitle: string;
}

const { welcome, tagline, subtitle } = Astro.props;
---

<div class="hero-content" id="hero-content">
  <span data-hero="badge" data-reveal="hero-badge" class="hero-badge">{welcome}</span>

  <h1 class="hero-title">
    {
      tagline.split("\n").map((line, index) => (
        <span
          data-reveal={`hero-title-line-${index + 1}`}
          data-hero={`title-line-${index + 1}`}
          class={`hero-title-line hero-title-line-1`}
        >
          {line}
        </span>
      ))
    }
    <span data-hero="title-line-3" class="hero-title-line hero-title-line-2">{subtitle}</span>
  </h1>
</div>

<style>
  .hero-content {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    padding: 2rem;
    text-align: center;
  }

  .js-ready .hero-content > * {
    animation: none;
    opacity: 0;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.375rem 1rem;
    background-color: rgba(200, 168, 78, 0.15);
    color: var(--color-gold-light);
    border: 1px solid rgba(200, 168, 78, 0.3);
    border-radius: 9999px;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    backdrop-filter: blur(8px);
  }

  .hero-title {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .hero-title-line {
    display: block;
    font-family: var(--font-heading);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero-title-line-1 {
    font-size: clamp(2rem, 5vw, var(--text-heading-xl));
    color: var(--color-earth-cream);
    line-height: 1.1;
  }

  .hero-title-line-2 {
    font-size: clamp(1rem, 2.5vw, var(--text-heading-sm));
    color: var(--color-earth-sand);
    line-height: 1.4;
    font-weight: 600;
    text-transform: none;
    letter-spacing: 0;
    font-style: italic;
  }
</style>
