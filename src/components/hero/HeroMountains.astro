<div class="hero-mountains" aria-hidden="true">
  <img class="hero-mountain" src="/assets/images/mountains.png" alt="" decoding="async" />
</div>
<div class="hero-spacer" aria-hidden="true"></div>

<style>
  .hero-mountains {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 100%;
    pointer-events: none;
    z-index: 5;
    overflow: hidden;
  }

  .hero-mountain {
    position: absolute;
    bottom: -190px;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: bottom center;
    opacity: 0.5;
    scale: 1 0.6;
  }

  .hero-spacer {
    height: 1px;
  }
</style>
