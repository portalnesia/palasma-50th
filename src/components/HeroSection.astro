---
import { CONTENT } from "@config/content.ts";
import HeroBackground from "./hero/HeroBackground.astro";
import HeroBokehOrbs from "./hero/HeroBokehOrbs.astro";
import HeroSparkles from "./hero/HeroSparkles.astro";
import HeroConfetti from "./hero/HeroConfetti.astro";
import HeroContent from "./hero/HeroContent.astro";
import HeroMountains from "./hero/HeroMountains.astro";

const { hero } = CONTENT;
---

<section id="hero" class="hero-section">
  <HeroBackground />
  <HeroBokehOrbs />
  <HeroSparkles />
  <HeroConfetti />
  <HeroContent welcome={hero.welcome} tagline={hero.tagline} subtitle={hero.subtitle} />
  <HeroMountains />
</section>

<style>
  .hero-section {
    position: relative;
    width: 100%;
    height: 100dvh;
    min-height: 600px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .js-reveal {
    opacity: 1 !important;
    transform: none !important;
  }
</style>

<script>
  import { setupHeroParallax } from "@utils/hero.ts";

  const section = document.getElementById("hero") as HTMLElement;
  const bg = section?.querySelector<HTMLElement>(".hero-bg");
  const content = document.getElementById("hero-content") as HTMLElement;

  if (section && bg && content) {
    setupHeroParallax(section, bg, content);
  }
</script>
