---
import { CONTENT } from "@config/content.ts";

const { hero } = CONTENT;
---

<section id="hero" class="hero-section">
  {/* ── Background layers ──────────────────────────────────── */}
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-bg-gradient-1"></div>
    <div class="hero-bg-gradient-2"></div>
    <div class="hero-bg-gradient-3"></div>
    <div class="hero-bg-gradient-4"></div>
    <div class="hero-bg-grain"></div>
  </div>

  {/* ── Bokeh orbs ─────────────────────────────────────────── */}
  <div class="hero-bokeh" aria-hidden="true">
    <div class="hero-bokeh-orb hero-bokeh-1"></div>
    <div class="hero-bokeh-orb hero-bokeh-2"></div>
    <div class="hero-bokeh-orb hero-bokeh-3"></div>
    <div class="hero-bokeh-orb hero-bokeh-4"></div>
    <div class="hero-bokeh-orb hero-bokeh-5"></div>
  </div>

  {/* ── Sparkles ───────────────────────────────────────────── */}
  <div class="hero-sparkles" aria-hidden="true">
    <span class="hero-sparkle hero-sparkle-1"></span>
    <span class="hero-sparkle hero-sparkle-2"></span>
    <span class="hero-sparkle hero-sparkle-3"></span>
    <span class="hero-sparkle hero-sparkle-4"></span>
    <span class="hero-sparkle hero-sparkle-5"></span>
    <span class="hero-sparkle hero-sparkle-6"></span>
  </div>

  {/* ── Floating confetti ──────────────────────────────────── */}
  <div class="hero-confetti" aria-hidden="true">
    <span class="hero-confetti-piece hero-confetti-1"></span>
    <span class="hero-confetti-piece hero-confetti-2"></span>
    <span class="hero-confetti-piece hero-confetti-3"></span>
    <span class="hero-confetti-piece hero-confetti-4"></span>
    <span class="hero-confetti-piece hero-confetti-5"></span>
    <span class="hero-confetti-piece hero-confetti-6"></span>
    <span class="hero-confetti-piece hero-confetti-7"></span>
    <span class="hero-confetti-piece hero-confetti-8"></span>
    <span class="hero-confetti-piece hero-confetti-9"></span>
    <span class="hero-confetti-piece hero-confetti-10"></span>
  </div>

  {/* ── Content ────────────────────────────────────────────── */}
  <div class="hero-content" id="hero-content">
    <span data-hero="badge" data-reveal="hero-badge" class="hero-badge">{hero.welcome}</span>

    <h1 class="hero-title">
      {
        // Split tagline into lines at newline characters
        hero.tagline.split("\n").map((line, index) => (
          <span
            data-reveal={`hero-title-line-${index + 1}`}
            data-hero={`title-line-${index + 1}`}
            class={`hero-title-line hero-title-line-1`}
          >
            {line}
          </span>
        ))
      }
      <span data-hero="title-line-3" class="hero-title-line hero-title-line-2">{hero.subtitle}</span
      >
    </h1>
  </div>

  {/* ── Mountain silhouettes (transition to sambutan) ──────── */}
  <div class="hero-mountains" aria-hidden="true">
    <img class="hero-mountain" src="/assets/images/mountains.png" alt="" decoding="async" />
  </div>

  <div class="hero-spacer" aria-hidden="true"></div>
</section>

<style>
  /* ── Section base ────────────────────────────────────────── */
  .hero-section {
    position: relative;
    width: 100%;
    height: 100dvh;
    min-height: 600px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* ── Background layers ───────────────────────────────────── */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      radial-gradient(ellipse 80% 80% at 50% 50%, rgba(200, 168, 78, 0.06) 0%, transparent 70%),
      linear-gradient(
        175deg,
        var(--color-navy-800) 0%,
        var(--color-navy-700) 50%,
        var(--color-navy) 100%
      );
  }

  .hero-bg-gradient-1 {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 80% 80% at 50% 50%,
      rgba(200, 168, 78, 0.06) 0%,
      transparent 70%
    );
  }

  .hero-bg-gradient-2 {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle 400px at 30% 70%,
      rgba(74, 124, 89, 0.08) 0%,
      transparent 100%
    );
  }

  .hero-bg-gradient-3 {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle 300px at 75% 35%,
      rgba(139, 105, 20, 0.06) 0%,
      transparent 100%
    );
  }

  /* Golden glow — opacity animated by GSAP */
  .hero-bg-gradient-4 {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle 500px at 50% 50%,
      rgba(200, 168, 78, 0.12) 0%,
      rgba(200, 168, 78, 0.04) 40%,
      transparent 70%
    );
    opacity: 0;
  }

  .hero-bg-grain {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 256px 256px;
    opacity: 0;
    mix-blend-mode: overlay;
  }

  /* ── Bokeh orbs ──────────────────────────────────────────── */
  .hero-bokeh {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }

  .hero-bokeh-orb {
    position: absolute;
    border-radius: 50%;
    opacity: 0;
  }

  .hero-bokeh-1 {
    width: 260px;
    height: 260px;
    top: 15%;
    left: 5%;
    background: radial-gradient(
      circle,
      rgba(200, 168, 78, 0.12) 0%,
      rgba(200, 168, 78, 0.04) 50%,
      transparent 70%
    );
    filter: blur(40px);
  }

  .hero-bokeh-2 {
    width: 200px;
    height: 200px;
    top: 55%;
    right: 8%;
    background: radial-gradient(
      circle,
      rgba(74, 124, 89, 0.15) 0%,
      rgba(74, 124, 89, 0.05) 50%,
      transparent 70%
    );
    filter: blur(35px);
  }

  .hero-bokeh-3 {
    width: 180px;
    height: 180px;
    bottom: 20%;
    left: 15%;
    background: radial-gradient(
      circle,
      rgba(212, 184, 134, 0.1) 0%,
      rgba(212, 184, 134, 0.03) 50%,
      transparent 70%
    );
    filter: blur(30px);
  }

  .hero-bokeh-4 {
    width: 220px;
    height: 220px;
    top: 25%;
    right: 20%;
    background: radial-gradient(
      circle,
      rgba(200, 168, 78, 0.1) 0%,
      rgba(200, 168, 78, 0.03) 50%,
      transparent 70%
    );
    filter: blur(50px);
  }

  .hero-bokeh-5 {
    width: 160px;
    height: 160px;
    bottom: 30%;
    right: 5%;
    background: radial-gradient(
      circle,
      rgba(74, 124, 89, 0.08) 0%,
      rgba(74, 124, 89, 0.02) 50%,
      transparent 70%
    );
    filter: blur(25px);
  }

  /* ── Sparkles ────────────────────────────────────────────── */
  .hero-sparkles {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }

  .hero-sparkle {
    position: absolute;
    width: 8px;
    height: 8px;
    background: var(--color-gold);
    clip-path: polygon(
      50% 0%,
      61% 35%,
      98% 35%,
      68% 57%,
      79% 91%,
      50% 70%,
      21% 91%,
      32% 57%,
      2% 35%,
      39% 35%
    );
  }

  .hero-sparkle-1 {
    width: 10px;
    height: 10px;
    left: 10%;
    top: 20%;
  }
  .hero-sparkle-2 {
    width: 6px;
    height: 6px;
    left: 22%;
    top: 65%;
  }
  .hero-sparkle-3 {
    width: 8px;
    height: 8px;
    left: 78%;
    top: 18%;
  }
  .hero-sparkle-4 {
    width: 7px;
    height: 7px;
    left: 85%;
    top: 60%;
  }
  .hero-sparkle-5 {
    width: 9px;
    height: 9px;
    left: 45%;
    top: 82%;
  }
  .hero-sparkle-6 {
    width: 6px;
    height: 6px;
    left: 55%;
    top: 12%;
  }

  /* ── Confetti ────────────────────────────────────────────── */
  .hero-confetti {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }

  .hero-confetti-piece {
    position: absolute;
    width: 8px;
    height: 4px;
    border-radius: 1px;
  }

  .hero-confetti-1 {
    background: var(--color-gold);
    left: 8%;
    top: 25%;
  }
  .hero-confetti-2 {
    background: var(--color-earth-sand);
    left: 18%;
    top: 70%;
    width: 6px;
    height: 3px;
  }
  .hero-confetti-3 {
    background: var(--color-earth-moss);
    left: 35%;
    top: 15%;
  }
  .hero-confetti-4 {
    background: var(--color-gold-light);
    left: 60%;
    top: 75%;
    width: 7px;
    height: 3px;
  }
  .hero-confetti-5 {
    background: var(--color-earth-cream);
    left: 75%;
    top: 20%;
  }
  .hero-confetti-6 {
    background: var(--color-gold-dark);
    left: 88%;
    top: 65%;
    width: 6px;
    height: 4px;
  }
  .hero-confetti-7 {
    background: var(--color-earth-moss-light);
    left: 25%;
    top: 80%;
  }
  .hero-confetti-8 {
    background: var(--color-gold);
    left: 50%;
    top: 88%;
    width: 7px;
    height: 3px;
  }
  .hero-confetti-9 {
    background: var(--color-earth-sand);
    left: 68%;
    top: 82%;
  }
  .hero-confetti-10 {
    background: var(--color-gold-light);
    left: 42%;
    top: 10%;
    width: 6px;
    height: 4px;
  }

  /* ── Content ─────────────────────────────────────────────── */
  .hero-content {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    padding: 2rem;
    text-align: center;
  }

  /* ── JS-ready: hide content, GSAP reveals on scroll ── */
  .js-ready .hero-content > * {
    animation: none;
    opacity: 0;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.375rem 1rem;
    background-color: rgba(200, 168, 78, 0.15);
    color: var(--color-gold-light);
    border: 1px solid rgba(200, 168, 78, 0.3);
    border-radius: 9999px;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    backdrop-filter: blur(8px);
  }

  .hero-title {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .hero-title-line {
    display: block;
    font-family: var(--font-heading);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero-title-line-1 {
    font-size: clamp(2rem, 5vw, var(--text-heading-xl));
    color: var(--color-earth-cream);
    line-height: 1.1;
  }

  .hero-title-line-2 {
    font-size: clamp(1rem, 2.5vw, var(--text-heading-sm));
    color: var(--color-earth-sand);
    line-height: 1.4;
    font-weight: 600;
    text-transform: none;
    letter-spacing: 0;
    font-style: italic;
  }

  .hero-spacer {
    height: 1px;
  }

  /* ── Mountain silhouettes transition ────────────────────── */
  .hero-mountains {
    position: absolute;
    bottom: -105px;
    left: 0;
    right: 0;
    height: 100%;
    pointer-events: none;
    z-index: 5;
    overflow: hidden;
  }

  .hero-mountain {
    position: absolute;
    bottom: -140px;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: bottom center;
    opacity: 0;
    scale: 1 0.6;
  }

  /* ── GSAP fallback: content visible without JS ────────────── */
  .js-reveal {
    opacity: 1 !important;
    transform: none !important;
  }
</style>

<script>
  import { setupHeroParallax } from "@utils/hero.ts";

  const section = document.getElementById("hero") as HTMLElement;
  const bg = section?.querySelector<HTMLElement>(".hero-bg");
  const content = document.getElementById("hero-content") as HTMLElement;

  if (section && bg && content) {
    setupHeroParallax(section, bg, content);
  }
</script>
