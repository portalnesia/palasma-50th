---
import { CONTACTS } from "@config/contacts.ts";
import { LINKS } from "@config/links.ts";
import { CONTENT } from "@config/content.ts";
import { version } from "@utils/version.ts";
import { buildVersion } from "@utils/version-build.ts";

const displayVersion = buildVersion || `${version}-local`;
const { footer } = CONTENT;
---

<footer id="site-footer" class="footer">
  <div class="footer-container">
    {/* ── Top ornamental line ─────────────────────────────── */}
    <div class="footer-ornament" aria-hidden="true">
      <div class="footer-ornament-line"></div>
      <div class="footer-ornament-diamond"></div>
      <div class="footer-ornament-line"></div>
    </div>

    {/* ── Main footer content ─────────────────────────────── */}
    <div class="footer-grid">
      {/* ── Contact Information ────────────────────────────── */}
      <div class="footer-section">
        <h3 class="footer-heading">Kontak Panitia</h3>
        <ul class="footer-contact-list">
          {
            CONTACTS.map((contact) => (
              <li class="footer-contact-item">
                <span class="footer-contact-name">{contact.name}</span>
                <span class="footer-contact-role">{contact.role}</span>
                <div class="footer-contact-links">
                  {contact.whatsapp && (
                    <a
                      href={contact.whatsapp}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="footer-contact-link"
                      aria-label={`WhatsApp ${contact.name}`}
                    >
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                      </svg>
                      <span>WhatsApp</span>
                    </a>
                  )}
                  {contact.phone && (
                    <a
                      href={`tel:${contact.phone}`}
                      class="footer-contact-link"
                      aria-label={`Telepon ${contact.name}`}
                    >
                      <svg
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                      </svg>
                      <span>{contact.phone}</span>
                    </a>
                  )}
                </div>
              </li>
            ))
          }
        </ul>
      </div>

      {/* ── Social Media ──────────────────────────────────── */}
      <div class="footer-section">
        <h3 class="footer-heading">Ikuti Kami</h3>
        <div class="footer-social-links">
          {
            LINKS.instagram && (
              <a
                href={LINKS.instagram}
                target="_blank"
                rel="noopener noreferrer"
                class="footer-social-link"
                aria-label="Instagram PALASMA"
              >
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
                </svg>
                <span>Instagram</span>
              </a>
            )
          }
          {
            LINKS.youtube && (
              <a
                href={LINKS.youtube}
                target="_blank"
                rel="noopener noreferrer"
                class="footer-social-link"
                aria-label="YouTube PALASMA"
              >
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
                </svg>
                <span>YouTube</span>
              </a>
            )
          }
        </div>
      </div>
    </div>

    {/* ── Credit & Copyright ──────────────────────────────── */}
    <div class="footer-bottom">
      <!-- <p class="footer-credit">{footer.credit}</p> -->
      <p class="footer-copyright">
        {footer.text} by <a href="https://portalnesia.com" target="_blank" rel="noopener noreferrer"
          >Portalnesia</a
        >
      </p>
      <p class="footer-version">v{displayVersion}</p>
    </div>
  </div>
</footer>

<style>
  /* ===== Footer Section ===== */
  .footer {
    position: relative;
    z-index: 50;
    background: linear-gradient(180deg, var(--color-navy) 0%, var(--color-navy-700) 100%);
    padding: 3rem 1.5rem 2rem;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* ── Ornamental divider ────────────────────────────────── */
  .footer-ornament {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .footer-ornament-line {
    width: 60px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-gold), transparent);
    opacity: 0.4;
  }

  .footer-ornament-diamond {
    width: 6px;
    height: 6px;
    background: var(--color-gold);
    transform: rotate(45deg);
    opacity: 0.5;
  }

  /* ── Grid layout ────────────────────────────────────────── */
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  /* ── Section headings ──────────────────────────────────── */
  .footer-heading {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-gold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  /* ── Contact list ──────────────────────────────────────── */
  .footer-contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-contact-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .footer-contact-name {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-earth-cream);
  }

  .footer-contact-role {
    font-size: 0.75rem;
    color: var(--color-earth-sand);
    opacity: 0.7;
  }

  .footer-contact-links {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.25rem;
  }

  .footer-contact-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.75rem;
    color: var(--color-gold);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-contact-link:hover {
    color: var(--color-gold-light);
  }

  .footer-contact-link svg {
    opacity: 0.8;
  }

  /* ── Social media links ────────────────────────────────── */
  .footer-social-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .footer-social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(200, 168, 78, 0.08);
    border: 1px solid rgba(200, 168, 78, 0.15);
    border-radius: 8px;
    color: var(--color-earth-cream);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 500;
    transition:
      background 0.2s,
      border-color 0.2s,
      color 0.2s;
  }

  .footer-social-link:hover {
    background: rgba(200, 168, 78, 0.15);
    border-color: rgba(200, 168, 78, 0.3);
    color: var(--color-gold);
  }

  .footer-social-link svg {
    opacity: 0.9;
  }

  /* ── Bottom section ────────────────────────────────────── */
  .footer-bottom {
    text-align: center;
    padding-top: 2rem;
    border-top: 1px solid rgba(200, 168, 78, 0.1);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-credit {
    font-size: 0.8rem;
    color: var(--color-earth-sand);
    opacity: 0.7;
    font-style: italic;
  }

  .footer-copyright {
    font-size: 0.75rem;
    color: rgba(245, 230, 200, 0.4);
  }

  .footer-version {
    font-size: 0.65rem;
    color: rgba(200, 168, 78, 0.35);
    font-family: monospace;
    letter-spacing: 0.05em;
  }

  /* ── Tablet and up ─────────────────────────────────────── */
  @media (min-width: 640px) {
    .footer {
      padding: 4rem 2rem 2.5rem;
    }

    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }

    .footer-heading {
      font-size: 1rem;
    }
  }

  /* ── Desktop ───────────────────────────────────────────── */
  @media (min-width: 1024px) {
    .footer {
      padding: 5rem 2rem 3rem;
    }

    .footer-ornament-line {
      width: 100px;
    }

    .footer-grid {
      gap: 4rem;
    }

    .footer-credit {
      font-size: 0.85rem;
    }

    .footer-copyright {
      font-size: 0.8rem;
    }
  }
</style>
