---
import CountdownItem from "@components/atoms/CountdownItem.astro";

const units = [
  { label: "Hari", id: "countdown-days" },
  { label: "Jam", id: "countdown-hours" },
  { label: "Menit", id: "countdown-minutes" },
  { label: "Detik", id: "countdown-seconds" },
];
---

<div class="event-countdown" data-reveal="event-countdown">
  {
    units.map((unit, i) => (
      <>
        <CountdownItem label={unit.label} value="00" id={unit.id} />
        {i < units.length - 1 && (
          <span class="event-countdown-sep" aria-hidden="true">
            :
          </span>
        )}
      </>
    ))
  }
</div>

<style>
  .event-countdown {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
    width: 100%;
  }

  .event-countdown-sep {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    color: var(--color-gold);
    opacity: 0.4;
    margin-top: -1.25rem;
    animation: event-countdown-sep-pulse 1.5s ease-in-out infinite;
  }

  @keyframes event-countdown-sep-pulse {
    0%,
    100% {
      opacity: 0.3;
    }
    50% {
      opacity: 0.7;
    }
  }

  @media (max-width: 768px) {
    .event-countdown {
      gap: 0.35rem;
    }
  }

  @media (max-width: 400px) {
    .event-countdown {
      gap: 0.25rem;
    }
  }
</style>
