---
interface Props {
  galleryTitle: string;
  emptyGallery: string;
  noMoreMessages: string;
  openFormLabel: string;
}

const { galleryTitle, emptyGallery, noMoreMessages, openFormLabel } = Astro.props;
---

<div class="ucapan-gallery-section js-required" data-reveal="ucapan-gallery" hidden>
  <h3 class="ucapan-gallery-title">{galleryTitle}</h3>

  <button type="button" class="ucapan-open-form-btn touch-target" id="ucapan-open-form-btn">
    <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
      ></path>
    </svg>
    <span>{openFormLabel}</span>
  </button>

  <div class="ucapan-scroll" id="ucapan-scroll">
    <ul class="ucapan-list" id="ucapan-gallery" role="list">
      <li class="ucapan-list-empty" id="ucapan-gallery-empty">
        {emptyGallery}
      </li>
    </ul>
    <div class="ucapan-scroll-sentinel" id="ucapan-scroll-sentinel"></div>
    <span class="ucapan-no-more" id="ucapan-no-more" hidden>{noMoreMessages}</span>
  </div>
</div>

<style>
  .ucapan-gallery-section {
    width: 100%;
  }

  .ucapan-gallery-title {
    text-align: center;
    font-size: var(--text-heading-sm);
    font-family: var(--font-heading);
    color: var(--color-earth-cream);
    margin: 0 0 1rem;
    font-weight: 600;
  }

  .ucapan-open-form-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.75rem 1.25rem;
    margin-bottom: 1rem;
    background: rgba(10, 31, 62, 0.4);
    border: 1px dashed rgba(200, 168, 78, 0.25);
    border-radius: 10px;
    color: var(--color-gold);
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.25s ease;
  }

  .ucapan-open-form-btn:hover {
    background: rgba(10, 31, 62, 0.6);
    border-color: rgba(200, 168, 78, 0.4);
  }

  .ucapan-open-form-btn svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .ucapan-scroll {
    max-height: 480px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(200, 168, 78, 0.25) transparent;
    border: 1px solid rgba(200, 168, 78, 0.08);
    border-radius: 12px;
    background: rgba(10, 31, 62, 0.2);
  }

  .ucapan-scroll::-webkit-scrollbar {
    width: 5px;
  }

  .ucapan-scroll::-webkit-scrollbar-track {
    background: transparent;
  }

  .ucapan-scroll::-webkit-scrollbar-thumb {
    background: rgba(200, 168, 78, 0.25);
    border-radius: 3px;
  }

  .ucapan-list {
    list-style: none;
    margin: 0;
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .ucapan-list-empty {
    text-align: center;
    color: rgba(212, 184, 134, 0.4);
    font-style: italic;
    padding: 2.5rem 1rem;
    font-size: var(--text-body-sm);
  }

  .ucapan-scroll-sentinel {
    height: 1px;
    width: 100%;
  }

  .ucapan-no-more {
    display: block;
    text-align: center;
    font-size: 0.8rem;
    color: rgba(212, 184, 134, 0.35);
    font-style: italic;
    padding: 0.75rem;
  }
</style>
