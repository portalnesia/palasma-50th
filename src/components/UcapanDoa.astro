---
import { CONTENT } from "@config/content.ts";
import { ASSETS } from "@config/assets.ts";
import UcapanFormCard from "@components/molecules/UcapanFormCard.astro";
import UcapanGallery from "@components/molecules/UcapanGallery.astro";
import UcapanNoscriptCard from "@components/atoms/UcapanNoscriptCard.astro";
import SideDecor from "@components/atoms/SideDecor.astro";
import FloatingParticles from "@components/atoms/FloatingParticles.astro";

const { ucapan } = CONTENT;

// Compute max batch (angkatan): current year minus 1978 (founding year), minus 2 skipped years
const PALASMA_BASE_YEAR = 1978;
const currentYear = new Date().getFullYear();
const maxBatch = currentYear - PALASMA_BASE_YEAR;

interface Props {
  useBg?: boolean;
}

const { useBg = false } = Astro.props;
---

<section id="ucapan-doa" class="ucapan-section">
  {/* ── Background layers ──────────────────────────────────── */}
  <div
    class:list={["ucapan-bg", { "has-bg-image": useBg }]}
    aria-hidden="true"
    style={useBg ? `--bg-url: url(${ASSETS.bg[7]})` : undefined}
  >
    <div class="ucapan-bg-gradient-1"></div>
    <div class="ucapan-bg-gradient-2"></div>
    <div class="ucapan-bg-gradient-3"></div>
    <div class="ucapan-bg-grain"></div>
  </div>

  {/* ── Mountain silhouettes (bottom) ──────────────────────── */}
  <div class="ucapan-mountains" aria-hidden="true">
    <svg
      class="ucapan-mountain ucapan-mountain-back"
      viewBox="0 0 1440 200"
      preserveAspectRatio="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        d="M0 200 L0 120 L120 80 L240 110 L360 50 L480 90 L600 30 L720 70 L840 20 L960 60 L1080 40 L1200 80 L1320 60 L1440 100 L1440 200 Z"
        fill="rgba(42, 75, 58, 0.25)"></path>
    </svg>
    <svg
      class="ucapan-mountain ucapan-mountain-front"
      viewBox="0 0 1440 200"
      preserveAspectRatio="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        d="M0 200 L0 140 L180 100 L360 130 L540 80 L720 120 L900 70 L1080 110 L1260 90 L1440 130 L1440 200 Z"
        fill="rgba(58, 102, 71, 0.2)"></path>
    </svg>
  </div>

  {/* ── Pine tree silhouettes (sides) ──────────────────────── */}
  <div class="ucapan-trees ucapan-trees-left" aria-hidden="true">
    <svg viewBox="0 0 60 120" xmlns="http://www.w3.org/2000/svg" class="ucapan-tree">
      <path
        d="M30 0 L10 45 L18 45 L5 80 L15 80 L0 120 L60 120 L45 80 L55 80 L42 45 L50 45 Z"
        fill="rgba(58, 102, 71, 0.15)"></path>
    </svg>
    <svg viewBox="0 0 60 120" xmlns="http://www.w3.org/2000/svg" class="ucapan-tree ucapan-tree-sm">
      <path
        d="M30 0 L12 40 L19 40 L7 75 L16 75 L2 110 L58 110 L44 75 L53 75 L41 40 L48 40 Z"
        fill="rgba(42, 75, 58, 0.12)"></path>
    </svg>
  </div>
  <div class="ucapan-trees ucapan-trees-right" aria-hidden="true">
    <svg viewBox="0 0 60 120" xmlns="http://www.w3.org/2000/svg" class="ucapan-tree">
      <path
        d="M30 0 L10 45 L18 45 L5 80 L15 80 L0 120 L60 120 L45 80 L55 80 L42 45 L50 45 Z"
        fill="rgba(58, 102, 71, 0.15)"></path>
    </svg>
    <svg viewBox="0 0 60 120" xmlns="http://www.w3.org/2000/svg" class="ucapan-tree ucapan-tree-sm">
      <path
        d="M30 0 L12 40 L19 40 L7 75 L16 75 L2 110 L58 110 L44 75 L53 75 L41 40 L48 40 Z"
        fill="rgba(74, 124, 89, 0.12)"></path>
    </svg>
  </div>

  {/* ── Floating gold particles ──────────────────────────────── */}
  <FloatingParticles prefix="ucapan" />

  {/* ── Decorative side lines ─────────────────────────────────── */}
  <SideDecor position="left" />
  <SideDecor position="right" />

  <div class="ucapan-container">
    {/* ── Title ──────────────────────────────────────────────── */}
    <h2 class="ucapan-title reveal-on-scroll reveal-fade-up">
      <span class="ucapan-title-star" aria-hidden="true">✦</span>
      <span class="ucapan-title-text">{ucapan.title}</span>
      <span class="ucapan-title-star" aria-hidden="true">✦</span>
    </h2>

    {/* ── Subtitle ──────────────────────────────────────────── */}
    <p class="ucapan-subtitle reveal-on-scroll reveal-fade-up" style="transition-delay: 100ms;">
      {ucapan.subtitle}
    </p>

    {/* ── Golden divider ──────────────────────────────────────── */}
    <div
      class="ucapan-divider reveal-on-scroll reveal-fade-up"
      style="transition-delay: 150ms;"
      aria-hidden="true"
    >
      <span class="ucapan-divider-line"></span>
      <span class="ucapan-divider-diamond">◆</span>
      <span class="ucapan-divider-line"></span>
    </div>

    {/* ── Body / description ────────────────────────────────── */}
    <p class="ucapan-body reveal-on-scroll reveal-fade-up" style="transition-delay: 200ms;">
      {ucapan.body}
    </p>

    <div
      class="w-full flex justify-center reveal-on-scroll reveal-fade-up"
      style="transition-delay: 300ms;"
    >
      <UcapanFormCard
        formName={ucapan.formName}
        formNamePlaceholder={ucapan.formNamePlaceholder}
        formBatch={ucapan.formBatch}
        formBatchPlaceholder={ucapan.formBatchPlaceholder}
        formBatchHint={ucapan.formBatchHint}
        formOrganization={ucapan.formOrganization}
        formOrganizationPlaceholder={ucapan.formOrganizationPlaceholder}
        formOrganizationHint={ucapan.formOrganizationHint}
        formMessage={ucapan.formMessage}
        formMessagePlaceholder={ucapan.formMessagePlaceholder}
        submitLabel={ucapan.submitLabel}
        submittingLabel={ucapan.submittingLabel}
        successMessage={ucapan.successMessage}
        errorMessage={ucapan.errorMessage}
        maxBatch={maxBatch}
      />
    </div>

    <div class="w-full reveal-on-scroll reveal-fade-up" style="transition-delay: 400ms;">
      <UcapanGallery
        galleryTitle="Ucapan dari Sahabat PALASMA"
        emptyGallery={ucapan.emptyGallery}
        noMoreMessages={ucapan.noMoreMessages}
        openFormLabel={ucapan.submitLabel}
      />
    </div>

    {/* ── Supabase unconfigured state ────────────────────────── */}
    <div class="ucapan-unconfigured" id="ucapan-unconfigured" hidden>
      <div class="ucapan-unconfigured-card">
        <svg
          class="ucapan-unconfigured-icon"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"></circle>
          <path d="M12 8v4M12 16h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"
          ></path>
        </svg>
        <p>{ucapan.supabaseUnconfigured}</p>
      </div>
    </div>
  </div>

  <UcapanNoscriptCard />
</section>

<script>
  import {
    isConfigured,
    validateForm,
    hasErrors,
    fetchMessages,
    insertMessage,
    subscribeToMessages,
    formatMessageDate,
    MAX_MESSAGE_LENGTH,
  } from "@utils/ucapan.ts";

  (async function () {
    "use strict";

    const section = document.getElementById("ucapan-doa");
    if (section) section.classList.add("js-enabled");

    // Show JS-only elements
    const dialog = document.getElementById("ucapan-dialog") as HTMLDialogElement | null;
    if (dialog) dialog.hidden = false;

    const gallerySection = section?.querySelector(
      ".ucapan-gallery-section.js-required",
    ) as HTMLElement | null;
    if (gallerySection) gallerySection.hidden = false;

    const noscriptEl = section?.querySelector(".js-fallback-only") as HTMLElement | null;
    if (noscriptEl) noscriptEl.style.display = "none";

    // Check Supabase config
    if (!isConfigured()) {
      console.warn("Supabase configuration missing. Ucapan feature disabled.");
      if (dialog) dialog.hidden = true;
      if (gallerySection) gallerySection.hidden = true;
      const unconfiguredEl = document.getElementById("ucapan-unconfigured") as HTMLElement | null;
      if (unconfiguredEl) unconfiguredEl.hidden = false;
      return;
    }

    // ── Dialog open / close + body scroll lock ──
    const openBtn = document.getElementById("ucapan-open-form-btn") as HTMLButtonElement | null;
    const closeBtn = document.getElementById("ucapan-dialog-close") as HTMLButtonElement | null;

    function openDialog() {
      if (!dialog) return;
      dialog.showModal();
      document.body.style.overflow = "hidden";
    }

    function closeDialog() {
      if (!dialog) return;
      dialog.close();
      document.body.style.overflow = "";
    }

    openBtn?.addEventListener("click", openDialog);
    closeBtn?.addEventListener("click", closeDialog);
    dialog?.addEventListener("click", (e) => {
      if (e.target === dialog) closeDialog();
    });
    dialog?.addEventListener("cancel", (e) => {
      e.preventDefault();
      closeDialog();
    });

    // DOM refs
    const nameInput = document.getElementById("ucapan-name") as HTMLInputElement | null;
    const batchSelect = document.getElementById("ucapan-batch") as HTMLSelectElement | null;
    const organizationInput = document.getElementById(
      "ucapan-organization",
    ) as HTMLInputElement | null;
    const messageTextarea = document.getElementById("ucapan-message") as HTMLTextAreaElement | null;
    const charCount = document.getElementById("ucapan-char-count") as HTMLElement | null;
    const submitBtn = document.getElementById("ucapan-submit") as HTMLButtonElement | null;
    const submitLabel = submitBtn?.querySelector(".ucapan-submit-label") as HTMLElement | null;
    const submitLoading = submitBtn?.querySelector(".ucapan-submit-loading") as HTMLElement | null;
    const successEl = document.getElementById("ucapan-success") as HTMLElement | null;
    const errorEl = document.getElementById("ucapan-error") as HTMLElement | null;
    const gallery = document.getElementById("ucapan-gallery") as HTMLElement | null;
    const galleryEmpty = document.getElementById("ucapan-gallery-empty") as HTMLElement | null;
    const nameError = document.getElementById("ucapan-name-error") as HTMLElement | null;
    const batchError = document.getElementById("ucapan-batch-error") as HTMLElement | null;
    const organizationError = document.getElementById(
      "ucapan-organization-error",
    ) as HTMLElement | null;
    const messageError = document.getElementById("ucapan-message-error") as HTMLElement | null;
    const noMoreEl = document.getElementById("ucapan-no-more") as HTMLElement | null;
    const scrollContainer = document.getElementById("ucapan-scroll") as HTMLElement | null;
    const sentinel = document.getElementById("ucapan-scroll-sentinel") as HTMLElement | null;

    // ── Helpers ──
    function escapeHtml(str: string): string {
      const div = document.createElement("div");
      div.textContent = str;
      return div.innerHTML;
    }

    function renderMessageItem(msg: {
      id: string;
      name: string;
      batch_year: number | null;
      organization: string | null;
      message: string;
      created_at: string;
    }): HTMLLIElement {
      const li = document.createElement("li");
      li.className = "ucapan-item";
      li.dataset.messageId = msg.id;

      const initials = msg.name
        .split(" ")
        .map((w) => w[0])
        .join("")
        .toUpperCase()
        .slice(0, 2);

      const batchLabel = msg.batch_year ? `PLM Angkatan ${msg.batch_year}` : "";
      const orgLabel = msg.organization ?? "";
      const subtitle = batchLabel || orgLabel || "";

      li.innerHTML = `
        <div class="ucapan-item-head">
          <div class="ucapan-item-avatar">${initials}</div>
          <div class="ucapan-item-meta">
            <span class="ucapan-item-name">${escapeHtml(msg.name)}</span>
            ${subtitle ? `<span class="ucapan-item-sub">${escapeHtml(subtitle)}</span>` : ""}
          </div>
          <span class="ucapan-item-date">${formatMessageDate(msg.created_at)}</span>
        </div>
        <p class="ucapan-item-message">${escapeHtml(msg.message)}</p>
      `;

      return li;
    }

    function updateCharCount() {
      const count = messageTextarea?.value?.length || 0;
      if (charCount) charCount.textContent = `${count}/${MAX_MESSAGE_LENGTH}`;
    }

    function showFeedback(type: "success" | "error") {
      if (type === "success") {
        if (successEl) successEl.hidden = false;
        if (errorEl) errorEl.hidden = true;
        setTimeout(() => {
          if (successEl) successEl.hidden = true;
        }, 5000);
      } else {
        if (errorEl) errorEl.hidden = false;
        if (successEl) successEl.hidden = true;
        setTimeout(() => {
          if (errorEl) errorEl.hidden = true;
        }, 5000);
      }
    }

    function resetFormErrors() {
      [nameError, batchError, organizationError, messageError].forEach((el) => {
        if (el) el.textContent = "";
      });
      [nameInput, batchSelect, organizationInput, messageTextarea].forEach((el) => {
        if (el) el.classList.remove("ucapan-input-error");
      });
    }

    function showFormError(
      field: "name" | "batch_year" | "organization" | "message",
      message: string,
    ) {
      const errorEl =
        field === "name"
          ? nameError
          : field === "batch_year"
            ? batchError
            : field === "organization"
              ? organizationError
              : messageError;
      const inputEl =
        field === "name"
          ? nameInput
          : field === "batch_year"
            ? batchSelect
            : field === "organization"
              ? organizationInput
              : messageTextarea;
      if (errorEl) errorEl.textContent = message;
      if (inputEl) inputEl.classList.add("ucapan-input-error");
    }

    // ── Pagination state ──
    const PAGE_SIZE = 10;
    let currentOffset = 0;
    let hasMore = true;
    let loadingMore = false;

    // ── Load messages ──
    async function loadMessages(reset = false) {
      if (loadingMore) return;
      loadingMore = true;

      if (reset) {
        currentOffset = 0;
        hasMore = true;
        if (gallery) {
          gallery.querySelectorAll(".ucapan-item").forEach((c) => c.remove());
        }
      }

      try {
        const messages = await fetchMessages({ limit: PAGE_SIZE, offset: currentOffset });

        if (messages.length < PAGE_SIZE) hasMore = false;
        currentOffset += messages.length;

        if (galleryEmpty && messages.length > 0) galleryEmpty.remove();

        messages.forEach((msg) => {
          gallery?.appendChild(renderMessageItem(msg));
        });

        if (hasMore) {
          if (noMoreEl) noMoreEl.hidden = true;
        } else {
          if (currentOffset > 0 && noMoreEl) noMoreEl.hidden = false;
        }
      } catch (err) {
        console.error("Error loading messages:", err);
        if (galleryEmpty) {
          galleryEmpty.textContent = "Gagal memuat ucapan. Silakan muat ulang halaman.";
          galleryEmpty.style.display = "block";
        }
      } finally {
        loadingMore = false;
      }
    }

    // ── IntersectionObserver for auto-load ──
    if (sentinel && scrollContainer) {
      const observer = new IntersectionObserver(
        (entries) => {
          if (entries[0].isIntersecting && hasMore && !loadingMore) {
            loadMessages();
          }
        },
        { root: scrollContainer, rootMargin: "0px 0px 100px 0px" },
      );
      observer.observe(sentinel);
    }

    // ── Submit message ──
    async function submitMessage() {
      resetFormErrors();
      const errors = validateForm(
        nameInput?.value?.trim() ?? "",
        batchSelect?.value ?? "",
        organizationInput?.value?.trim() ?? "",
        messageTextarea?.value?.trim() ?? "",
      );

      if (hasErrors(errors)) {
        if (errors.name) showFormError("name", errors.name);
        if (errors.batch_year) showFormError("batch_year", errors.batch_year);
        if (errors.organization) showFormError("organization", errors.organization);
        if (errors.message) showFormError("message", errors.message);
        return;
      }

      const name = nameInput!.value.trim();
      const batch_year = batchSelect!.value;
      const organization = organizationInput!.value.trim();
      const message = messageTextarea!.value.trim();

      if (submitLabel) submitLabel.hidden = true;
      if (submitLoading) submitLoading.hidden = false;
      if (submitBtn) submitBtn.disabled = true;

      try {
        const result = await insertMessage(name, batch_year, organization, message);

        if (result.success) {
          if (galleryEmpty) galleryEmpty.remove();
          const existingItem = gallery?.querySelector(`[data-message-id="${result.message.id}"]`);
          if (!existingItem) {
            gallery?.prepend(renderMessageItem(result.message));
          }

          if (nameInput) nameInput.value = "";
          if (batchSelect) batchSelect.value = "";
          if (organizationInput) organizationInput.value = "";
          if (messageTextarea) messageTextarea.value = "";
          updateCharCount();

          currentOffset = 0;
          hasMore = true;
          if (noMoreEl) noMoreEl.hidden = true;

          if (scrollContainer) scrollContainer.scrollTop = 0;

          showFeedback("success");
          closeDialog();
        } else {
          showFeedback("error");
        }
      } catch (err) {
        console.error("Error submitting message:", err);
        showFeedback("error");
      } finally {
        if (submitLabel) submitLabel.hidden = false;
        if (submitLoading) submitLoading.hidden = true;
        if (submitBtn) submitBtn.disabled = false;
      }
    }

    // ── Realtime ──
    let unsubscribeRealtime: (() => void) | null = null;

    try {
      unsubscribeRealtime = await subscribeToMessages((msg) => {
        if (galleryEmpty) galleryEmpty.remove();
        const existingItem = gallery?.querySelector(`[data-message-id="${msg.id}"]`);
        if (!existingItem) {
          const li = renderMessageItem(msg);
          li.style.animation = "ucapanItemSlideIn 0.4s ease-out";
          gallery?.prepend(li);
        }
      });
      window.addEventListener("beforeunload", () => unsubscribeRealtime?.());
    } catch {
      console.log("Realtime unavailable.");
    }

    // ── Event listeners ──
    messageTextarea?.addEventListener("input", updateCharCount);

    const form = document.getElementById("ucapan-form");
    form?.addEventListener("submit", (e) => {
      e.preventDefault();
      submitMessage();
    });

    // ── Init ──
    await loadMessages();
  })();
</script>

<style>
  .ucapan-section {
    position: relative;
    width: 100%;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    overflow: hidden;
    padding: var(--spacing-section-lg) 0;
    /* Transition from warm earth bronze to starry deep navy-black */
    background: linear-gradient(180deg, var(--color-navy-800) 0%, var(--color-navy-900) 100%);
  }

  .ucapan-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .ucapan-bg.has-bg-image {
    background:
      linear-gradient(135deg, rgba(8, 73, 140, 0.55) 0%, rgba(12, 92, 179, 0.55) 100%),
      var(--bg-url) center/cover no-repeat fixed;
  }

  .ucapan-bg-gradient-1 {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 60% at 50% 10%, rgba(12, 92, 179, 0.5) 0%, transparent 80%),
      radial-gradient(ellipse 50% 50% at 85% 25%, rgba(200, 168, 78, 0.08) 0%, transparent 60%),
      radial-gradient(ellipse 45% 45% at 15% 75%, rgba(74, 124, 89, 0.06) 0%, transparent 60%);
  }

  .ucapan-bg-gradient-2 {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      170deg,
      transparent 0%,
      rgba(12, 92, 179, 0.3) 40%,
      rgba(42, 75, 58, 0.15) 70%,
      transparent 100%
    );
  }

  .ucapan-bg-gradient-3 {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 0%, rgba(12, 92, 179, 0.2) 100%);
  }

  .ucapan-bg-grain {
    position: absolute;
    inset: 0;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 200px;
  }

  .ucapan-mountains {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 200px;
    z-index: 1;
    pointer-events: none;
  }

  .ucapan-mountain {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .ucapan-trees {
    position: absolute;
    bottom: 0;
    z-index: 2;
    pointer-events: none;
    display: flex;
    gap: 10px;
    align-items: flex-end;
  }

  .ucapan-trees-left {
    left: 20px;
  }

  .ucapan-trees-right {
    right: 20px;
  }

  .ucapan-tree {
    width: 50px;
    height: 100px;
  }

  .ucapan-tree-sm {
    width: 35px;
    height: 70px;
  }

  /* SideDecor and FloatingParticles are handled by their own atom components */

  .ucapan-container {
    position: relative;
    z-index: 5;
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .ucapan-title {
    text-align: center;
    font-size: var(--text-heading-xl);
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-earth-cream);
    margin: 0 0 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .ucapan-divider {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 0.75rem 0;
  }

  .ucapan-divider-line {
    width: 60px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(200, 168, 78, 0.5), transparent);
  }

  .ucapan-divider-diamond {
    color: var(--color-gold);
    font-size: 0.5rem;
    opacity: 0.6;
  }

  .ucapan-bottom-flourish {
    margin-top: 2.5rem;
    display: flex;
    justify-content: center;
  }

  .ucapan-title-star {
    color: var(--color-gold);
    font-size: 1.2em;
    opacity: 0.7;
  }

  .ucapan-title-text {
    background: linear-gradient(135deg, var(--color-earth-cream), var(--color-gold-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .ucapan-subtitle {
    text-align: center;
    font-size: var(--text-body);
    color: var(--color-earth-sand);
    margin: 0 0 0.5rem;
    opacity: 0.9;
  }

  .ucapan-body {
    text-align: center;
    font-size: var(--text-body-sm);
    color: rgba(212, 184, 134, 0.8);
    max-width: 600px;
    margin: 0 0 2.5rem;
    line-height: 1.6;
  }

  .js-required[hidden] {
    display: none;
  }

  .js-fallback-only {
    display: block;
  }

  .js-enabled .js-fallback-only {
    display: none;
  }

  @media (max-width: 768px) {
    .ucapan-section {
      padding: var(--spacing-section) 0;
    }

    .ucapan-title {
      font-size: var(--text-heading-lg);
    }

    .ucapan-trees-left,
    .ucapan-trees-right {
      display: none;
    }

    .ucapan-corner {
      width: 28px;
      height: 28px;
    }

    .ucapan-corner-tl {
      top: 16px;
      left: 16px;
    }

    .ucapan-corner-tr {
      top: 16px;
      right: 16px;
    }

    .ucapan-corner-bl {
      bottom: 16px;
      left: 16px;
    }

    .ucapan-corner-br {
      bottom: 16px;
      right: 16px;
    }
  }

