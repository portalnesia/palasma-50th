---
import { CONTENT } from "@config/content.ts";
import UcapanFormCard from "@components/molecules/UcapanFormCard.astro";
import UcapanGallery from "@components/molecules/UcapanGallery.astro";
import UcapanNoscriptCard from "@components/atoms/UcapanNoscriptCard.astro";
import SideDecor from "@components/atoms/SideDecor.astro";
import FloatingParticles from "@components/atoms/FloatingParticles.astro";

const { ucapan } = CONTENT;

// Compute max batch (angkatan): current year minus 1978 (founding year), minus 2 skipped years
const PALASMA_BASE_YEAR = 1978;
const currentYear = new Date().getFullYear();
const maxBatch = currentYear - PALASMA_BASE_YEAR;
---

<section id="ucapan-doa" class="ucapan-section" data-load-more={ucapan.loadMoreLabel} data-loading={ucapan.loadingLabel}>
  {/* ── Background layers ──────────────────────────────────── */}
  <div class="ucapan-bg" aria-hidden="true">
    <div class="ucapan-bg-gradient-1"></div>
    <div class="ucapan-bg-gradient-2"></div>
    <div class="ucapan-bg-gradient-3"></div>
    <div class="ucapan-bg-grain"></div>
  </div>

  {/* ── Mountain silhouettes (bottom) ──────────────────────── */}
  <div class="ucapan-mountains" aria-hidden="true">
    <svg
      class="ucapan-mountain ucapan-mountain-back"
      viewBox="0 0 1440 200"
      preserveAspectRatio="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        d="M0 200 L0 120 L120 80 L240 110 L360 50 L480 90 L600 30 L720 70 L840 20 L960 60 L1080 40 L1200 80 L1320 60 L1440 100 L1440 200 Z"
        fill="rgba(42, 75, 58, 0.25)"></path>
    </svg>
    <svg
      class="ucapan-mountain ucapan-mountain-front"
      viewBox="0 0 1440 200"
      preserveAspectRatio="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        d="M0 200 L0 140 L180 100 L360 130 L540 80 L720 120 L900 70 L1080 110 L1260 90 L1440 130 L1440 200 Z"
        fill="rgba(58, 102, 71, 0.2)"></path>
    </svg>
  </div>

  {/* ── Pine tree silhouettes (sides) ──────────────────────── */}
  <div class="ucapan-trees ucapan-trees-left" aria-hidden="true">
    <svg viewBox="0 0 60 120" xmlns="http://www.w3.org/2000/svg" class="ucapan-tree">
      <path
        d="M30 0 L10 45 L18 45 L5 80 L15 80 L0 120 L60 120 L45 80 L55 80 L42 45 L50 45 Z"
        fill="rgba(58, 102, 71, 0.15)"></path>
    </svg>
    <svg viewBox="0 0 60 120" xmlns="http://www.w3.org/2000/svg" class="ucapan-tree ucapan-tree-sm">
      <path
        d="M30 0 L12 40 L19 40 L7 75 L16 75 L2 110 L58 110 L44 75 L53 75 L41 40 L48 40 Z"
        fill="rgba(42, 75, 58, 0.12)"></path>
    </svg>
  </div>
  <div class="ucapan-trees ucapan-trees-right" aria-hidden="true">
    <svg viewBox="0 0 60 120" xmlns="http://www.w3.org/2000/svg" class="ucapan-tree">
      <path
        d="M30 0 L10 45 L18 45 L5 80 L15 80 L0 120 L60 120 L45 80 L55 80 L42 45 L50 45 Z"
        fill="rgba(58, 102, 71, 0.15)"></path>
    </svg>
    <svg viewBox="0 0 60 120" xmlns="http://www.w3.org/2000/svg" class="ucapan-tree ucapan-tree-sm">
      <path
        d="M30 0 L12 40 L19 40 L7 75 L16 75 L2 110 L58 110 L44 75 L53 75 L41 40 L48 40 Z"
        fill="rgba(74, 124, 89, 0.12)"></path>
    </svg>
  </div>

  {/* ── Floating gold particles ──────────────────────────────── */}
  <FloatingParticles prefix="ucapan" />

  {/* ── Decorative side lines ─────────────────────────────────── */}
  <SideDecor position="left" />
  <SideDecor position="right" />

  <div class="ucapan-container">
    {/* ── Title ──────────────────────────────────────────────── */}
    <h2 class="ucapan-title" data-reveal="ucapan-title">
      <span class="ucapan-title-star" aria-hidden="true">✦</span>
      <span class="ucapan-title-text">{ucapan.title}</span>
      <span class="ucapan-title-star" aria-hidden="true">✦</span>
    </h2>

    {/* ── Subtitle ──────────────────────────────────────────── */}
    <p class="ucapan-subtitle" data-reveal="ucapan-subtitle">
      {ucapan.subtitle}
    </p>

    {/* ── Golden divider ──────────────────────────────────────── */}
    <div class="ucapan-divider" data-reveal="ucapan-divider" aria-hidden="true">
      <span class="ucapan-divider-line"></span>
      <span class="ucapan-divider-diamond">◆</span>
      <span class="ucapan-divider-line"></span>
    </div>

    {/* ── Body / description ────────────────────────────────── */}
    <p class="ucapan-body" data-reveal="ucapan-body">
      {ucapan.body}
    </p>

    <UcapanFormCard
      formName={ucapan.formName}
      formNamePlaceholder={ucapan.formNamePlaceholder}
      formBatch={ucapan.formBatch}
      formBatchPlaceholder={ucapan.formBatchPlaceholder}
      formMessage={ucapan.formMessage}
      formMessagePlaceholder={ucapan.formMessagePlaceholder}
      submitLabel={ucapan.submitLabel}
      submittingLabel={ucapan.submittingLabel}
      successMessage={ucapan.successMessage}
      errorMessage={ucapan.errorMessage}
      maxBatch={maxBatch}
    />

    <UcapanGallery
      galleryTitle="Ucapan dari Sahabat PALASMA"
      emptyGallery={ucapan.emptyGallery}
      loadMoreLabel={ucapan.loadMoreLabel}
      noMoreMessages={ucapan.noMoreMessages}
    />

    {/* ── Supabase unconfigured state ────────────────────────── */}
    <div class="ucapan-unconfigured" id="ucapan-unconfigured" hidden>
      <div class="ucapan-unconfigured-card">
        <svg
          class="ucapan-unconfigured-icon"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"></circle>
          <path d="M12 8v4M12 16h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"
          ></path>
        </svg>
        <p>{ucapan.supabaseUnconfigured}</p>
      </div>
    </div>
  </div>

  <UcapanNoscriptCard />
</section>

<script>
  import {
    isConfigured,
    validateForm,
    hasErrors,
    fetchMessages,
    insertMessage,
    subscribeToMessages,
    formatMessageDate,
    MAX_MESSAGE_LENGTH,
  } from "@utils/ucapan.ts";

  (async function () {
    "use strict";

    const section = document.getElementById("ucapan-doa");
    if (section) section.classList.add("js-enabled");

    const loadMoreLabel = section?.dataset.loadMore ?? "Muat Lebih Banyak";
    const loadingLabel = section?.dataset.loading ?? "Memuat...";

    // Show JS-only elements
    const formCard = section?.querySelector(".ucapan-form-card.js-required") as HTMLElement | null;
    if (formCard) formCard.hidden = false;

    const gallerySection = section?.querySelector(".ucapan-gallery-section.js-required") as HTMLElement | null;
    if (gallerySection) gallerySection.hidden = false;

    const noscriptEl = section?.querySelector(".js-fallback-only") as HTMLElement | null;
    if (noscriptEl) noscriptEl.style.display = "none";

    // Check Supabase config
    if (!isConfigured()) {
      console.warn("Supabase configuration missing. Ucapan feature disabled.");
      if (formCard) formCard.hidden = true;
      if (gallerySection) gallerySection.hidden = true;
      const unconfiguredEl = document.getElementById("ucapan-unconfigured") as HTMLElement | null;
      if (unconfiguredEl) unconfiguredEl.hidden = false;
      return;
    }

    // DOM refs
    const nameInput = document.getElementById("ucapan-name") as HTMLInputElement | null;
    const batchSelect = document.getElementById("ucapan-batch") as HTMLSelectElement | null;
    const messageTextarea = document.getElementById("ucapan-message") as HTMLTextAreaElement | null;
    const charCount = document.getElementById("ucapan-char-count") as HTMLElement | null;
    const submitBtn = document.getElementById("ucapan-submit") as HTMLButtonElement | null;
    const submitLabel = submitBtn?.querySelector(".ucapan-submit-label") as HTMLElement | null;
    const submitLoading = submitBtn?.querySelector(".ucapan-submit-loading") as HTMLElement | null;
    const successEl = document.getElementById("ucapan-success") as HTMLElement | null;
    const errorEl = document.getElementById("ucapan-error") as HTMLElement | null;
    const gallery = document.getElementById("ucapan-gallery") as HTMLElement | null;
    const galleryEmpty = document.getElementById("ucapan-gallery-empty") as HTMLElement | null;
    const nameError = document.getElementById("ucapan-name-error") as HTMLElement | null;
    const batchError = document.getElementById("ucapan-batch-error") as HTMLElement | null;
    const messageError = document.getElementById("ucapan-message-error") as HTMLElement | null;
    const loadMoreWrapper = document.getElementById("ucapan-load-more-wrapper") as HTMLElement | null;
    const loadMoreBtn = document.getElementById("ucapan-load-more") as HTMLButtonElement | null;
    const noMoreEl = document.getElementById("ucapan-no-more") as HTMLElement | null;

    // ── Helpers ──
    function escapeHtml(str: string): string {
      const div = document.createElement("div");
      div.textContent = str;
      return div.innerHTML;
    }

    function renderMessageCard(msg: { id: string; name: string; batch_year: number; message: string; created_at: string }): HTMLDivElement {
      const card = document.createElement("div");
      card.className = "ucapan-card";
      card.dataset.messageId = msg.id;

      const initials = msg.name
        .split(" ")
        .map((w) => w[0])
        .join("")
        .toUpperCase()
        .slice(0, 2);

      card.innerHTML = `
        <div class="ucapan-card-quote" aria-hidden="true">"</div>
        <div class="ucapan-card-avatar">${initials}</div>
        <div class="ucapan-card-name">${escapeHtml(msg.name)}</div>
        <div class="ucapan-card-batch">${escapeHtml(String(msg.batch_year))}</div>
        <p class="ucapan-card-message">${escapeHtml(msg.message)}</p>
        <div class="ucapan-card-date">${formatMessageDate(msg.created_at)}</div>
      `;

      return card;
    }

    function updateCharCount() {
      const count = messageTextarea?.value?.length || 0;
      if (charCount) charCount.textContent = `${count}/${MAX_MESSAGE_LENGTH}`;
    }

    function showFeedback(type: "success" | "error") {
      if (type === "success") {
        if (successEl) successEl.hidden = false;
        if (errorEl) errorEl.hidden = true;
        setTimeout(() => { if (successEl) successEl.hidden = true; }, 5000);
      } else {
        if (errorEl) errorEl.hidden = false;
        if (successEl) successEl.hidden = true;
        setTimeout(() => { if (errorEl) errorEl.hidden = true; }, 5000);
      }
    }

    function resetFormErrors() {
      [nameError, batchError, messageError].forEach((el) => { if (el) el.textContent = ""; });
      [nameInput, batchSelect, messageTextarea].forEach((el) => {
        if (el) el.classList.remove("ucapan-input-error");
      });
    }

    function showFormError(field: "name" | "batch_year" | "message", message: string) {
      const errorEl = field === "name" ? nameError : field === "batch_year" ? batchError : messageError;
      const inputEl = field === "name" ? nameInput : field === "batch_year" ? batchSelect : messageTextarea;
      if (errorEl) errorEl.textContent = message;
      if (inputEl) inputEl.classList.add("ucapan-input-error");
    }

    // ── Pagination state ──
    const PAGE_SIZE = 10;
    let currentOffset = 0;
    let hasMore = true;
    let loadingMore = false;

    // ── Load messages ──
    async function loadMessages(reset = false) {
      if (loadingMore) return;
      loadingMore = true;

      if (reset) {
        currentOffset = 0;
        hasMore = true;
        if (gallery) {
          gallery.querySelectorAll(".ucapan-card").forEach((c) => c.remove());
        }
      }

      try {
        const messages = await fetchMessages({ limit: PAGE_SIZE, offset: currentOffset });

        if (messages.length < PAGE_SIZE) hasMore = false;
        currentOffset += messages.length;

        if (galleryEmpty && messages.length > 0) galleryEmpty.remove();

        messages.forEach((msg) => {
          gallery?.appendChild(renderMessageCard(msg));
        });

        if (hasMore) {
          if (loadMoreWrapper) loadMoreWrapper.hidden = false;
          if (noMoreEl) noMoreEl.hidden = true;
        } else {
          if (loadMoreWrapper) loadMoreWrapper.hidden = true;
          if (currentOffset > 0 && noMoreEl) noMoreEl.hidden = false;
        }
      } catch (err) {
        console.error("Error loading messages:", err);
        if (galleryEmpty) {
          galleryEmpty.textContent = "Gagal memuat ucapan. Silakan muat ulang halaman.";
          galleryEmpty.style.display = "block";
        }
      } finally {
        loadingMore = false;
      }
    }

    // ── Submit message ──
    async function submitMessage() {
      resetFormErrors();
      const errors = validateForm(
        nameInput?.value?.trim() ?? "",
        batchSelect?.value ?? "",
        messageTextarea?.value?.trim() ?? "",
      );

      if (hasErrors(errors)) {
        if (errors.name) showFormError("name", errors.name);
        if (errors.batch_year) showFormError("batch_year", errors.batch_year);
        if (errors.message) showFormError("message", errors.message);
        return;
      }

      const name = nameInput!.value.trim();
      const batch_year = batchSelect!.value;
      const message = messageTextarea!.value.trim();

      if (submitLabel) submitLabel.hidden = true;
      if (submitLoading) submitLoading.hidden = false;
      if (submitBtn) submitBtn.disabled = true;

      try {
        const result = await insertMessage(name, batch_year, message);

        if (result.success) {
          if (galleryEmpty) galleryEmpty.remove();
          const existingCard = gallery?.querySelector(`[data-message-id="${result.message.id}"]`);
          if (!existingCard) {
            gallery?.prepend(renderMessageCard(result.message));
          }

          if (nameInput) nameInput.value = "";
          if (batchSelect) batchSelect.value = "";
          if (messageTextarea) messageTextarea.value = "";
          updateCharCount();

          currentOffset = 0;
          hasMore = true;
          if (loadMoreWrapper) loadMoreWrapper.hidden = false;
          if (noMoreEl) noMoreEl.hidden = true;

          showFeedback("success");
        } else {
          showFeedback("error");
        }
      } catch (err) {
        console.error("Error submitting message:", err);
        showFeedback("error");
      } finally {
        if (submitLabel) submitLabel.hidden = false;
        if (submitLoading) submitLoading.hidden = true;
        if (submitBtn) submitBtn.disabled = false;
      }
    }

    // ── Realtime ──
    let unsubscribeRealtime: (() => void) | null = null;

    try {
      unsubscribeRealtime = await subscribeToMessages((msg) => {
        if (galleryEmpty) galleryEmpty.remove();
        const existingCard = gallery?.querySelector(`[data-message-id="${msg.id}"]`);
        if (!existingCard) {
          const card = renderMessageCard(msg);
          card.style.animation = "ucapanCardSlideIn 0.4s ease-out";
          gallery?.prepend(card);
        }
      });
      window.addEventListener("beforeunload", () => unsubscribeRealtime?.());
    } catch {
      console.log("Realtime unavailable.");
    }

    // ── Event listeners ──
    messageTextarea?.addEventListener("input", updateCharCount);

    const form = document.getElementById("ucapan-form");
    form?.addEventListener("submit", (e) => {
      e.preventDefault();
      submitMessage();
    });

    loadMoreBtn?.addEventListener("click", async () => {
      if (loadingMore || !hasMore) return;
      loadMoreBtn.textContent = loadingLabel + "...";
      loadMoreBtn.disabled = true;
      await loadMessages();
      loadMoreBtn.textContent = loadMoreLabel;
      loadMoreBtn.disabled = false;
    });

    // ── Init ──
    await loadMessages();
  })();
</script>

<script>
  import { setupUcapanAnimations } from "@utils/ucapan-gsap.ts";

  const section = document.getElementById("ucapan-doa") as HTMLElement;
  if (section) {
    setupUcapanAnimations(section);
  }
</script>

<style>
  .ucapan-section {
    position: relative;
    width: 100%;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    overflow: hidden;
    padding: var(--spacing-section-lg) 0;
  }

  .ucapan-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .ucapan-bg-gradient-1 {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 60% at 50% 30%, rgba(74, 124, 89, 0.08) 0%, transparent 70%),
      radial-gradient(ellipse 50% 50% at 20% 80%, rgba(58, 102, 71, 0.06) 0%, transparent 60%),
      radial-gradient(ellipse 40% 40% at 80% 70%, rgba(200, 168, 78, 0.05) 0%, transparent 50%);
  }

  .ucapan-bg-gradient-2 {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      170deg,
      transparent 0%,
      rgba(10, 31, 62, 0.3) 40%,
      rgba(42, 75, 58, 0.15) 70%,
      transparent 100%
    );
  }

  .ucapan-bg-gradient-3 {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 0%, rgba(10, 31, 62, 0.2) 100%);
  }

  .ucapan-bg-grain {
    position: absolute;
    inset: 0;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 200px;
  }

  .ucapan-mountains {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 200px;
    z-index: 1;
    pointer-events: none;
  }

  .ucapan-mountain {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .ucapan-trees {
    position: absolute;
    bottom: 0;
    z-index: 2;
    pointer-events: none;
    display: flex;
    gap: 10px;
    align-items: flex-end;
  }

  .ucapan-trees-left {
    left: 20px;
  }

  .ucapan-trees-right {
    right: 20px;
  }

  .ucapan-tree {
    width: 50px;
    height: 100px;
  }

  .ucapan-tree-sm {
    width: 35px;
    height: 70px;
  }

  /* SideDecor and FloatingParticles are handled by their own atom components */

  .ucapan-container {
    position: relative;
    z-index: 5;
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .ucapan-title {
    text-align: center;
    font-size: var(--text-heading-xl);
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-earth-cream);
    margin: 0 0 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .ucapan-divider {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 0.75rem 0;
  }

  .ucapan-divider-line {
    width: 60px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(200, 168, 78, 0.5), transparent);
  }

  .ucapan-divider-diamond {
    color: var(--color-gold);
    font-size: 0.5rem;
    opacity: 0.6;
  }

  .ucapan-bottom-flourish {
    margin-top: 2.5rem;
    display: flex;
    justify-content: center;
  }

  .ucapan-title-star {
    color: var(--color-gold);
    font-size: 1.2em;
    opacity: 0.7;
  }

  .ucapan-title-text {
    background: linear-gradient(135deg, var(--color-earth-cream), var(--color-gold-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .ucapan-subtitle {
    text-align: center;
    font-size: var(--text-body);
    color: var(--color-earth-sand);
    margin: 0 0 0.5rem;
    opacity: 0.9;
  }

  .ucapan-body {
    text-align: center;
    font-size: var(--text-body-sm);
    color: rgba(212, 184, 134, 0.8);
    max-width: 600px;
    margin: 0 0 2.5rem;
    line-height: 1.6;
  }

  .ucapan-card {
    position: relative;
    background: rgba(10, 31, 62, 0.5);
    border: 1px solid rgba(200, 168, 78, 0.12);
    border-radius: 12px;
    padding: 1.5rem 1.25rem 1.25rem;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition:
      border-color 0.25s,
      transform 0.25s;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    overflow: hidden;
  }

  .ucapan-card:hover {
    border-color: rgba(200, 168, 78, 0.3);
    transform: translateY(-2px);
  }

  .ucapan-card-quote {
    position: absolute;
    top: -8px;
    right: 12px;
    font-size: 4rem;
    font-family: Georgia, serif;
    color: rgba(200, 168, 78, 0.12);
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }

  .ucapan-card-avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-earth-moss), var(--color-earth-moss-dark));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-earth-cream);
    font-family: var(--font-heading);
    flex-shrink: 0;
    border: 1px solid rgba(200, 168, 78, 0.2);
  }

  .ucapan-card-name {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-earth-cream);
    font-family: var(--font-heading);
  }

  .ucapan-card-batch {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-gold);
    background: rgba(200, 168, 78, 0.1);
    border: 1px solid rgba(200, 168, 78, 0.2);
    border-radius: 20px;
    padding: 2px 10px;
    width: fit-content;
    letter-spacing: 0.03em;
  }

  .ucapan-card-message {
    font-size: var(--text-body-sm);
    color: rgba(212, 184, 134, 0.85);
    line-height: 1.6;
    margin: 0;
    word-break: break-word;
  }

  .ucapan-card-date {
    font-size: 0.7rem;
    color: rgba(212, 184, 134, 0.4);
    margin-top: 0.5rem;
    font-variant-numeric: tabular-nums;
  }

  @keyframes ucapanCardSlideIn {
    from {
      opacity: 0;
      transform: translateY(-20px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .js-required[hidden] {
    display: none;
  }

  .js-fallback-only {
    display: block;
  }

  .js-enabled .js-fallback-only {
    display: none;
  }

  @media (max-width: 768px) {
    .ucapan-section {
      padding: var(--spacing-section) 0;
    }

    .ucapan-title {
      font-size: var(--text-heading-lg);
    }

    .ucapan-trees-left,
    .ucapan-trees-right {
      display: none;
    }

    .ucapan-corner {
      width: 28px;
      height: 28px;
    }

    .ucapan-corner-tl {
      top: 16px;
      left: 16px;
    }

    .ucapan-corner-tr {
      top: 16px;
