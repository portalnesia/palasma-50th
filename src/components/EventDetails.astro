---
import { EVENT } from "@config/site.ts";
import { LINKS } from "@config/links.ts";
import { ASSETS } from "@config/assets.ts";
import BackgroundLayers from "@components/atoms/BackgroundLayers.astro";
import FloatingParticles from "@components/atoms/FloatingParticles.astro";
import SideDecor from "@components/atoms/SideDecor.astro";
import SectionTitle from "@components/atoms/SectionTitle.astro";
import OrnamentFlourish from "@components/atoms/OrnamentFlourish.astro";
import CountdownTimer from "@components/molecules/CountdownTimer.astro";
import InfoCard from "@components/molecules/InfoCard.astro";

interface Props {
  useBg?: boolean;
}

const { useBg = false } = Astro.props;
---

<section
  id="event-details"
  class:list={["event-section", { "has-bg-image": useBg }]}
  style={useBg ? `--bg-url: url(${ASSETS.bg[4]})` : undefined}
>
  <BackgroundLayers />

  <FloatingParticles prefix="event" />

  <SideDecor position="left" />
  <SideDecor position="right" />

  <div class="event-container">
    <OrnamentFlourish position="top" />

    <SectionTitle text="Info Acara" />

    <CountdownTimer />

    <InfoCard
      items={[
        {
          icon: "event",
          label: "Acara",
          value: EVENT.name,
          dataReveal: "event-info-row-0",
        },
        {
          icon: "date",
          label: "Tanggal",
          value: EVENT.dateLabel,
          dataReveal: "event-info-row-1",
        },
        {
          icon: "time",
          label: "Waktu",
          value: EVENT.time,
          dataReveal: "event-info-row-2",
        },
        {
          icon: "location",
          label: "Lokasi",
          value: EVENT.location,
          dataReveal: "event-info-row-3",
        },
      ]}
    />

    <div
      class="event-maps-wrapper reveal-on-scroll reveal-fade-up"
      style="transition-delay: 450ms;"
    >
      <div class="event-maps-container">
        <iframe
          class="event-maps-embed"
          src={LINKS.mapsEmbed}
          loading="lazy"
          title="Lokasi Acara — Aranka Tempasan"
          allowfullscreen
          referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
    </div>

    <OrnamentFlourish position="bottom" />
  </div>
</section>

<script>
  import { startCountdown } from "@utils/event-details";

  // Countdown
  const targetDate = new Date("2026-08-29T16:00:00+08:00");
  const elements = {
    days: document.getElementById("countdown-days")!,
    hours: document.getElementById("countdown-hours")!,
    minutes: document.getElementById("countdown-minutes")!,
    seconds: document.getElementById("countdown-seconds")!,
  };
  const countdownCleanup = startCountdown(targetDate, elements);

  document.addEventListener("astro:before-swap", () => {
    countdownCleanup();
  });
</script>

<style>
  /* ===== Event Details Section ===== */
  .event-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 1.5rem 6rem;
    overflow: hidden;
    /* Deep Forest Green gradient for highly distinct section transition */
    background: linear-gradient(180deg, #0a1f3e 0%, #020c05 100%);
  }

  .event-section.has-bg-image {
    background:
      linear-gradient(135deg, rgba(5, 16, 35, 0.55) 0%, rgba(10, 31, 62, 0.55) 100%),
      var(--bg-url) center/cover no-repeat;
  }

  /* ── Balloon decorations (bday-balloon style) ─────────── */
  .event-balloons {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 3;
    overflow: hidden;
  }

  .bday-balloon {
    position: absolute;
    opacity: 0;
  }

  .bday-balloon-body {
    border-radius: 50% 50% 50% 50% / 55% 55% 45% 45%;
    position: relative;
  }

  .bday-balloon-body::after {
    content: "";
    position: absolute;
    bottom: -6px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 7px solid inherit;
  }

  .bday-balloon-string {
    width: 1px;
    height: 40px;
    margin: 0 auto;
    background: linear-gradient(to bottom, rgba(200, 168, 78, 0.4), transparent);
  }

  .event-bday-1 {
    left: 2%;
    top: 15%;
  }
  .event-bday-1 .bday-balloon-body {
    width: 36px;
    height: 46px;
  }

  .event-bday-2 {
    left: 6%;
    top: 55%;
  }
  .event-bday-2 .bday-balloon-body {
    width: 28px;
    height: 36px;
  }

  .event-bday-3 {
    left: 11%;
    top: 30%;
  }
  .event-bday-3 .bday-balloon-body {
    width: 44px;
    height: 57px;
  }

  .event-bday-4 {
    left: 18%;
    top: 70%;
  }
  .event-bday-4 .bday-balloon-body {
    width: 30px;
    height: 39px;
  }

  .event-bday-5 {
    right: 3%;
    top: 20%;
  }
  .event-bday-5 .bday-balloon-body {
    width: 40px;
    height: 52px;
  }

  .event-bday-6 {
    right: 9%;
    top: 60%;
  }
  .event-bday-6 .bday-balloon-body {
    width: 32px;
    height: 42px;
  }

  .event-bday-7 {
    right: 15%;
    top: 10%;
  }
  .event-bday-7 .bday-balloon-body {
    width: 38px;
    height: 49px;
  }

  .event-bday-8 {
    right: 20%;
    top: 45%;
  }
  .event-bday-8 .bday-balloon-body {
    width: 42px;
    height: 55px;
  }

  .event-bday-9 {
    left: 25%;
    top: 80%;
  }
  .event-bday-9 .bday-balloon-body {
    width: 26px;
    height: 34px;
  }

  .event-bday-10 {
    right: 28%;
    top: 75%;
  }
  .event-bday-10 .bday-balloon-body {
    width: 34px;
    height: 44px;
  }

  .event-bday-11 {
    left: 42%;
    top: 5%;
  }
  .event-bday-11 .bday-balloon-body {
    width: 28px;
    height: 36px;
  }

  .event-bday-12 {
    right: 35%;
    top: 85%;
  }
  .event-bday-12 .bday-balloon-body {
    width: 30px;
    height: 39px;
  }

  .event-container {
    position: relative;
    z-index: 2;
    max-width: 720px;
    width: 100%;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .event-maps-wrapper {
    width: 100%;
    max-width: 580px;
  }

  .event-maps-container {
    position: relative;
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(200, 168, 78, 0.12);
    aspect-ratio: 16 / 9;
  }

  .event-maps-embed {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  /* ── Responsive (mobile-first) ──────────────────────────── */
  @media (max-width: 768px) {
    .event-section {
      padding: 4rem 1.25rem 5rem;
    }
  }

  @media (max-width: 400px) {
    .event-section {
      padding: 3rem 1rem 4rem;
    }
  }
</style>
