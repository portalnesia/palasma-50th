---
import { CONTENT } from "@config/content.ts";
import { ASSETS } from "@config/assets.ts";
import TwibbonUploadCard from "@components/molecules/TwibbonUploadCard.astro";

interface Props {
  useBg?: boolean;
}

const { useBg = false } = Astro.props;
const { twibbon } = CONTENT;
const twibbonFrameUrl = ASSETS.twibbon.frame;
---

<section id="twibbon" class:list={["twibbon-section", { "has-bg-image": useBg }]}>
  {/* ── Background layers ──────────────────────────────────── */}
  <div class="twibbon-bg" aria-hidden="true">
    <div class="twibbon-bg-gradient-1"></div>
    <div class="twibbon-bg-gradient-2"></div>
    <div class="twibbon-bg-gradient-3"></div>
    <div class="twibbon-bg-grain"></div>
  </div>

  {/* ── Floating gold particles ──────────────────────────────── */}
  <div class="twibbon-particles" aria-hidden="true">
    <span class="twibbon-particle twibbon-particle-1"></span>
    <span class="twibbon-particle twibbon-particle-2"></span>
    <span class="twibbon-particle twibbon-particle-3"></span>
    <span class="twibbon-particle twibbon-particle-4"></span>
    <span class="twibbon-particle twibbon-particle-5"></span>
    <span class="twibbon-particle twibbon-particle-6"></span>
  </div>

  {/* ── Decorative side lines ─────────────────────────────────── */}
  <div class="twibbon-side-decor twibbon-side-left" aria-hidden="true">
    <div class="twibbon-side-line"></div>
    <div class="twibbon-side-dot"></div>
    <div class="twibbon-side-line"></div>
  </div>
  <div class="twibbon-side-decor twibbon-side-right" aria-hidden="true">
    <div class="twibbon-side-line"></div>
    <div class="twibbon-side-dot"></div>
    <div class="twibbon-side-line"></div>
  </div>

  <div class="twibbon-container">
    {/* ── Top ornamental flourish ──────────────────────────── */}
    <div class="twibbon-ornament-top" data-reveal="twibbon-ornament-top" aria-hidden="true">
      <svg
        class="twibbon-flourish"
        viewBox="0 0 200 30"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M100 15 C85 5, 60 5, 40 15 S10 25, 0 15"
          stroke="url(#twibbon-gold-grad-l)"
          stroke-width="1"
          fill="none"
          opacity="0.5"></path>
        <path
          d="M100 15 C115 5, 140 5, 160 15 S190 25, 200 15"
          stroke="url(#twibbon-gold-grad-r)"
          stroke-width="1"
          fill="none"
          opacity="0.5"></path>
        <circle cx="100" cy="15" r="3" fill="#c8a84e" opacity="0.8"></circle>
        <circle cx="100" cy="15" r="6" stroke="#c8a84e" stroke-width="0.5" fill="none" opacity="0.3"
        ></circle>
        <defs>
          <linearGradient id="twibbon-gold-grad-l" x1="200" y1="15" x2="0" y2="15">
            <stop offset="0%" stop-color="#c8a84e" stop-opacity="0"></stop>
            <stop offset="100%" stop-color="#c8a84e" stop-opacity="1"></stop>
          </linearGradient>
          <linearGradient id="twibbon-gold-grad-r" x1="0" y1="15" x2="200" y2="15">
            <stop offset="0%" stop-color="#c8a84e" stop-opacity="0"></stop>
            <stop offset="100%" stop-color="#c8a84e" stop-opacity="1"></stop>
          </linearGradient>
        </defs>
      </svg>
    </div>

    {/* ── Title ──────────────────────────────────────────────── */}
    <h2 class="twibbon-title" data-reveal="twibbon-title">
      <span class="twibbon-title-star" aria-hidden="true">✦</span>
      <span class="twibbon-title-text">{twibbon.title}</span>
      <span class="twibbon-title-star" aria-hidden="true">✦</span>
    </h2>

    {/* ── Subtitle ──────────────────────────────────────────── */}
    <p class="twibbon-subtitle" data-reveal="twibbon-subtitle">
      {twibbon.subtitle}
    </p>

    {/* ── Body / persuasive text ────────────────────────────── */}
    <p class="twibbon-body" data-reveal="twibbon-body">
      {twibbon.body}
    </p>

    <TwibbonUploadCard
      ctaLabel={twibbon.ctaLabel}
      downloadLabel={twibbon.downloadLabel}
      resetLabel={twibbon.resetLabel}
      frameUrl={twibbonFrameUrl}
    />

    {/* ── Bottom ornamental flourish ─────────────────────── */}
    <div class="twibbon-ornament-bottom" data-reveal="twibbon-ornament-bottom" aria-hidden="true">
      <div class="twibbon-ornament-line"></div>
      <span class="twibbon-ornament-diamond">◆</span>
      <div class="twibbon-ornament-line"></div>
    </div>
  </div>

  {/* ── Script ─────────────────────────────────────────────── */}
  <script>
    import { setupTwibbon } from "@utils/twibbon.ts";

    const section = document.getElementById("twibbon");
    if (section) {
      setupTwibbon(section);
    }
  </script>

  {
    /* ── Frame overlay CSS + hidden canvas (must be global since Croppie creates DOM dynamically) ─ */
  }
  <style is:global>
    /* Hidden canvas for compositing — never visible */
    .twibbon-canvas {
      display: none;
    }

    /* Transparent boundary background (like Croppie.tsx) */
    #twibbon .cr-boundary {
      background-image: url("/assets/images/transparent.jpg") !important;
      background-size: cover !important;
      background-position: center !important;
    }

    /* Twibbon frame overlay on top of the viewport (z-index: 5 per PRD) */
    #twibbon .cr-viewport::after {
      content: "";
      position: absolute;
      inset: 0;
      background-image: url("/assets/images/twibbon.png");
      background-size: 100% 100%;
      background-repeat: no-repeat;
      background-position: center;
      z-index: 5;
      pointer-events: none;
    }
  </style>
</section>

<style>
  .twibbon-section {
    position: relative;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 6rem 1.5rem;
    box-sizing: border-box;
    /* Transition from deep forest green to deep slate twilight */
    background: linear-gradient(180deg, #020c05 0%, #031424 100%);
  }

  .twibbon-section.has-bg-image {
    background:
      radial-gradient(ellipse 80% 80% at 50% 50%, rgba(200, 168, 78, 0.06) 0%, transparent 70%),
      linear-gradient(
        175deg,
        rgba(5, 16, 35, 0.55) 0%,
        rgba(6, 21, 44, 0.55) 50%,
        rgba(10, 31, 62, 0.55) 100%
      ),
      url("/assets/images/bg/5.jpeg") center/cover no-repeat fixed;
  }

  .twibbon-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: radial-gradient(
      ellipse 80% 80% at 50% 30%,
      rgba(110, 143, 191, 0.09) 0%,
      transparent 70%
    );
  }

  .twibbon-bg-gradient-1 {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 80% 80% at 50% 50%,
      rgba(200, 168, 78, 0.06) 0%,
      transparent 70%
    );
  }

  .twibbon-bg-gradient-2 {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle 400px at 70% 30%,
      rgba(74, 124, 89, 0.08) 0%,
      transparent 100%
    );
  }

  .twibbon-bg-gradient-3 {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle 300px at 25% 65%,
      rgba(139, 105, 20, 0.06) 0%,
      transparent 100%
    );
  }

  .twibbon-bg-grain {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 256px 256px;
    opacity: 0;
    mix-blend-mode: overlay;
  }

  .twibbon-particles {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }

  .twibbon-particle {
    position: absolute;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(200, 168, 78, 0.8) 0%, rgba(200, 168, 78, 0) 70%);
    animation: twibbon-float 8s ease-in-out infinite;
  }

  .twibbon-particle-1 {
    top: 12%;
    left: 15%;
    animation-delay: 0s;
    animation-duration: 7s;
  }
  .twibbon-particle-2 {
    top: 25%;
    right: 20%;
    animation-delay: 1.2s;
    animation-duration: 9s;
  }
  .twibbon-particle-3 {
    bottom: 30%;
    left: 10%;
    animation-delay: 2.4s;
    animation-duration: 6s;
  }
  .twibbon-particle-4 {
    top: 60%;
    right: 12%;
    animation-delay: 0.8s;
    animation-duration: 10s;
  }
  .twibbon-particle-5 {
    bottom: 15%;
    left: 40%;
    animation-delay: 3.1s;
    animation-duration: 8s;
  }
  .twibbon-particle-6 {
    top: 45%;
    left: 55%;
    animation-delay: 1.8s;
    animation-duration: 7.5s;
  }

  @keyframes twibbon-float {
    0%,
    100% {
      transform: translateY(0) scale(1);
      opacity: 0.4;
    }
    50% {
      transform: translateY(-20px) scale(1.3);
      opacity: 0.9;
    }
  }

  .twibbon-side-decor {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    z-index: 1;
  }

  .twibbon-side-left {
    left: 1.5rem;
  }
  .twibbon-side-right {
    right: 1.5rem;
  }

  .twibbon-side-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, transparent, rgba(200, 168, 78, 0.3), transparent);
  }

  .twibbon-side-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(200, 168, 78, 0.5);
  }

  @media (max-width: 768px) {
    .twibbon-side-decor {
      display: none;
    }
  }

  .twibbon-container {
    position: relative;
    z-index: 2;
    max-width: 640px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .twibbon-ornament-top {
    width: 200px;
    height: 30px;
  }

  .twibbon-flourish {
    width: 100%;
    height: 100%;
  }

  .twibbon-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0;
    text-align: center;
  }

  .twibbon-title-text {
    font-family: "Cinzel Decorative", "Playfair Display", serif;
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 700;
    color: #c8a84e;
    letter-spacing: 0.05em;
    text-shadow: 0 0 40px rgba(200, 168, 78, 0.3);
  }

  .twibbon-title-star {
    color: #c8a84e;
    font-size: 0.875rem;
    opacity: 0.6;
  }

  .twibbon-subtitle {
    font-family: "Inter", system-ui, sans-serif;
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.85);
    text-align: center;
    margin: 0;
    line-height: 1.6;
    max-width: 500px;
  }

  .twibbon-body {
    font-family: "Inter", system-ui, sans-serif;
    font-size: clamp(0.875rem, 2vw, 1rem);
    font-weight: 300;
    color: rgba(255, 255, 255, 0.6);
    text-align: center;
    margin: 0;
    line-height: 1.7;
    max-width: 480px;
  }

  .twibbon-ornament-bottom {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .twibbon-ornament-line {
    width: 60px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(200, 168, 78, 0.4), transparent);
  }

  .twibbon-ornament-diamond {
    color: rgba(200, 168, 78, 0.4);
    font-size: 0.5rem;
  }

  @media (max-width: 480px) {
    .twibbon-section {
      padding: 4rem 1rem;
    }
  }
</style>
