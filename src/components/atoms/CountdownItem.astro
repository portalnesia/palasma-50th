---
interface Props {
  label: string;
  value: string;
  id: string;
}

const { label, value, id } = Astro.props;
---

<div class="event-countdown-item">
  <span class="event-countdown-value" id={id}>{value}</span>
  <span class="event-countdown-label">{label}</span>
</div>

<style>
  .event-countdown-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    min-width: 60px;
  }
  .event-countdown-value {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(2rem, 6vw, 3.5rem);
    line-height: 1;
    letter-spacing: 0.05em;
    background: linear-gradient(
      180deg,
      var(--color-gold-light) 0%,
      var(--color-gold) 50%,
      var(--color-gold-dark) 100%
    );
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 0 15px rgba(200, 168, 78, 0.2));
    min-width: 2ch;
    text-align: center;
  }
  .event-countdown-label {
    font-family: var(--font-body);
    font-size: clamp(0.65rem, 1.5vw, 0.8rem);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-earth-sand);
    opacity: 0.7;
  }
</style>
