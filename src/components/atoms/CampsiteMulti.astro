---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={["campsite-multi", className]} aria-hidden="true">
  <!-- Tent 1 (left, large) -->
  <div class="camp-item camp-tent-1" data-reveal="camp-tent-1">
    <svg viewBox="0 0 120 80" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M60 5 L10 75 L25 75 L35 55 L60 75 L85 55 L95 75 L110 75 Z"
        fill="rgba(58, 102, 71, 0.18)"></path>
      <path
        d="M60 5 L10 75 L25 75 L35 55 L60 75 L85 55 L95 75 L110 75 Z"
        stroke="rgba(200, 168, 78, 0.12)"
        stroke-width="0.5"
        fill="none"></path>
      <path d="M50 75 L60 55 L70 75 Z" fill="rgba(12, 92, 179, 0.3)"></path>
    </svg>
  </div>

  <!-- Tent 2 (right, medium) -->
  <div class="camp-item camp-tent-2" data-reveal="camp-tent-2">
    <svg viewBox="0 0 100 70" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M50 5 L8 65 L20 65 L28 48 L50 65 L72 48 L80 65 L92 65 Z"
        fill="rgba(42, 75, 58, 0.15)"></path>
      <path
        d="M50 5 L8 65 L20 65 L28 48 L50 65 L72 48 L80 65 L92 65 Z"
        stroke="rgba(200, 168, 78, 0.1)"
        stroke-width="0.5"
        fill="none"></path>
      <path d="M42 65 L50 48 L58 65 Z" fill="rgba(12, 92, 179, 0.25)"></path>
    </svg>
  </div>

  <!-- Tent 3 (center-left, small) -->
  <div class="camp-item camp-tent-3" data-reveal="camp-tent-3">
    <svg viewBox="0 0 80 55" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M40 3 L5 50 L15 50 L22 38 L40 50 L58 38 L65 50 L75 50 Z"
        fill="rgba(58, 102, 71, 0.12)"></path>
      <path
        d="M40 3 L5 50 L15 50 L22 38 L40 50 L58 38 L65 50 L75 50 Z"
        stroke="rgba(200, 168, 78, 0.08)"
        stroke-width="0.5"
        fill="none"></path>
    </svg>
  </div>

  <!-- Campfire 1 (between tent 1 and 2) -->
  <div class="camp-item camp-fire-1" data-reveal="camp-fire-1">
    <svg viewBox="0 0 50 60" xmlns="http://www.w3.org/2000/svg">
      <line
        x1="12"
        y1="55"
        x2="38"
        y2="48"
        stroke="rgba(139, 90, 43, 0.25)"
        stroke-width="2.5"
        stroke-linecap="round"></line>
      <line
        x1="38"
        y1="55"
        x2="12"
        y2="48"
        stroke="rgba(139, 90, 43, 0.2)"
        stroke-width="2.5"
        stroke-linecap="round"></line>
      <path
        d="M25 8 Q32 20 30 32 Q28 40 25 42 Q22 40 20 32 Q18 20 25 8 Z"
        fill="rgba(200, 168, 78, 0.15)"></path>
      <path
        d="M25 16 Q29 24 28 34 Q27 38 25 39 Q23 38 22 34 Q21 24 25 16 Z"
        fill="rgba(218, 165, 32, 0.1)"></path>
      <circle cx="20" cy="12" r="0.8" fill="rgba(200, 168, 78, 0.2)"></circle>
      <circle cx="30" cy="10" r="0.6" fill="rgba(200, 168, 78, 0.15)"></circle>
    </svg>
  </div>

  <!-- Campfire 2 (near tent 3) -->
  <div class="camp-item camp-fire-2" data-reveal="camp-fire-2">
    <svg viewBox="0 0 40 50" xmlns="http://www.w3.org/2000/svg">
      <line
        x1="10"
        y1="45"
        x2="30"
        y2="40"
        stroke="rgba(139, 90, 43, 0.2)"
        stroke-width="2"
        stroke-linecap="round"></line>
      <line
        x1="30"
        y1="45"
        x2="10"
        y2="40"
        stroke="rgba(139, 90, 43, 0.18)"
        stroke-width="2"
        stroke-linecap="round"></line>
      <path
        d="M20 6 Q26 16 24 26 Q23 32 20 33 Q17 32 16 26 Q14 16 20 6 Z"
        fill="rgba(200, 168, 78, 0.12)"></path>
      <path
        d="M20 12 Q23 18 22 26 Q21 30 20 30.5 Q19 30 18 26 Q17 18 20 12 Z"
        fill="rgba(218, 165, 32, 0.08)"></path>
    </svg>
  </div>

  <!-- Lantern 1 (left) -->
  <div class="camp-item camp-lantern-1" data-reveal="camp-lantern-1">
    <svg viewBox="0 0 36 60" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M15 6 Q18 1 21 6"
        stroke="rgba(200, 168, 78, 0.18)"
        stroke-width="1.2"
        fill="none"
        stroke-linecap="round"></path>
      <rect x="12" y="6" width="12" height="3" rx="1" fill="rgba(200, 168, 78, 0.1)"></rect>
      <path
        d="M12 9 L10 40 Q10 43 13 43 L23 43 Q26 43 26 40 L24 9 Z"
        fill="rgba(200, 168, 78, 0.05)"
        stroke="rgba(200, 168, 78, 0.08)"
        stroke-width="0.4"></path>
      <path
        d="M18 16 Q21 22 20 30 Q19.5 34 18 35 Q16.5 34 16 30 Q15 22 18 16 Z"
        fill="rgba(218, 165, 32, 0.1)"></path>
      <circle cx="18" cy="26" r="8" fill="rgba(200, 168, 78, 0.03)"></circle>
      <rect x="11" y="43" width="14" height="2" rx="1" fill="rgba(200, 168, 78, 0.08)"></rect>
      <line
        x1="14"
        y1="45"
        x2="12"
        y2="49"
        stroke="rgba(200, 168, 78, 0.08)"
        stroke-width="0.8"
        stroke-linecap="round"></line>
      <line
        x1="22"
        y1="45"
        x2="24"
        y2="49"
        stroke="rgba(200, 168, 78, 0.08)"
        stroke-width="0.8"
        stroke-linecap="round"></line>
    </svg>
  </div>

  <!-- Lantern 2 (right) -->
  <div class="camp-item camp-lantern-2" data-reveal="camp-lantern-2">
    <svg viewBox="0 0 30 50" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M12 5 Q15 1 18 5"
        stroke="rgba(200, 168, 78, 0.15)"
        stroke-width="1"
        fill="none"
        stroke-linecap="round"></path>
      <rect x="10" y="5" width="10" height="2.5" rx="0.8" fill="rgba(200, 168, 78, 0.08)"></rect>
      <path
        d="M10 7.5 L8.5 33 Q8.5 35.5 11 35.5 L19 35.5 Q21.5 35.5 21.5 33 L20 7.5 Z"
        fill="rgba(200, 168, 78, 0.04)"
        stroke="rgba(200, 168, 78, 0.07)"
        stroke-width="0.4"></path>
      <path
        d="M15 13 Q17.5 18 17 25 Q16.5 28 15 29 Q13.5 28 13 25 Q12.5 18 15 13 Z"
        fill="rgba(218, 165, 32, 0.08)"></path>
      <rect x="9.5" y="35.5" width="11" height="1.8" rx="0.8" fill="rgba(200, 168, 78, 0.07)"
      ></rect>
    </svg>
  </div>

  <!-- Lantern 3 (center) -->
  <div class="camp-item camp-lantern-3" data-reveal="camp-lantern-3">
    <svg viewBox="0 0 26 44" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M11 4 Q13 0.5 15 4"
        stroke="rgba(200, 168, 78, 0.12)"
        stroke-width="0.8"
        fill="none"
        stroke-linecap="round"></path>
      <rect x="9" y="4" width="8" height="2" rx="0.6" fill="rgba(200, 168, 78, 0.07)"></rect>
      <path
        d="M9 6 L7.5 28 Q7.5 30 9.5 30 L16.5 30 Q18.5 30 18.5 28 L17 6 Z"
        fill="rgba(200, 168, 78, 0.035)"
        stroke="rgba(200, 168, 78, 0.06)"
        stroke-width="0.3"></path>
      <path
        d="M13 11 Q15 15 14.5 21 Q14 24 13 24.5 Q12 24 11.5 21 Q11 15 13 11 Z"
        fill="rgba(218, 165, 32, 0.07)"></path>
      <rect x="8.5" y="30" width="9" height="1.5" rx="0.6" fill="rgba(200, 168, 78, 0.06)"></rect>
    </svg>
  </div>
</div>

<style>
  .campsite-multi {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
  }

  .camp-item {
    position: absolute;
  }

  /* Tents */
  .camp-tent-1 {
    bottom: 12%;
    left: 8%;
  }

  .camp-tent-1 svg {
    width: 100px;
    height: 70px;
  }

  .camp-tent-2 {
    bottom: 15%;
    right: 10%;
  }

  .camp-tent-2 svg {
    width: 85px;
    height: 60px;
  }

  .camp-tent-3 {
    bottom: 10%;
    left: 35%;
  }

  .camp-tent-3 svg {
    width: 65px;
    height: 45px;
  }

  /* Campfires */
  .camp-fire-1 {
    bottom: 14%;
    left: 28%;
  }

  .camp-fire-1 svg {
    width: 40px;
    height: 50px;
  }

  .camp-fire-2 {
    bottom: 11%;
    left: 48%;
  }

  .camp-fire-2 svg {
    width: 32px;
    height: 40px;
  }

  /* Lanterns */
  .camp-lantern-1 {
    bottom: 18%;
    left: 18%;
  }

  .camp-lantern-1 svg {
    width: 30px;
    height: 50px;
  }

  .camp-lantern-2 {
    bottom: 20%;
    right: 20%;
  }

  .camp-lantern-2 svg {
    width: 25px;
    height: 42px;
  }

  .camp-lantern-3 {
    bottom: 16%;
    right: 38%;
  }

  .camp-lantern-3 svg {
    width: 22px;
    height: 36px;
  }

  @media (max-width: 640px) {
    .camp-tent-1 {
      bottom: 10%;
      left: 5%;
    }

    .camp-tent-1 svg {
      width: 70px;
      height: 50px;
    }

    .camp-tent-2 {
      bottom: 12%;
      right: 6%;
    }

    .camp-tent-2 svg {
      width: 60px;
      height: 42px;
    }

    .camp-tent-3 {
      bottom: 8%;
      left: 32%;
    }

    .camp-tent-3 svg {
      width: 50px;
      height: 35px;
    }

    .camp-fire-1 {
      bottom: 11%;
      left: 24%;
    }

    .camp-fire-1 svg {
      width: 30px;
      height: 38px;
    }

    .camp-fire-2 {
      bottom: 9%;
      left: 44%;
    }

    .camp-fire-2 svg {
      width: 25px;
      height: 32px;
    }

    .camp-lantern-1 {
      bottom: 15%;
      left: 14%;
    }

    .camp-lantern-1 svg {
      width: 22px;
      height: 38px;
    }

    .camp-lantern-2 {
      bottom: 16%;
      right: 14%;
    }

    .camp-lantern-2 svg {
      width: 20px;
      height: 34px;
    }

    .camp-lantern-3 {
      bottom: 13%;
      right: 34%;
    }

    .camp-lantern-3 svg {
      width: 18px;
      height: 30px;
    }
  }
</style>
