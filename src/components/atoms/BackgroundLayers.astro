---
interface Props {
  prefix?: string;
}

const { prefix = "event" } = Astro.props;
---

<div class="event-bg" aria-hidden="true">
  <div class="event-bg-gradient-1"></div>
  <div class="event-bg-gradient-2"></div>
  <div class="event-bg-gradient-3"></div>
  <div class="event-bg-grain"></div>
</div>

<style>
  .event-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .event-bg-gradient-1,
  .event-bg-gradient-2,
  .event-bg-gradient-3 {
    position: absolute;
    inset: 0;
  }

  .event-bg-gradient-1 {
    background: radial-gradient(
      ellipse 70% 50% at 50% 30%,
      rgba(200, 168, 78, 0.05) 0%,
      transparent 60%
    );
  }

  .event-bg-gradient-2 {
    background: radial-gradient(
      ellipse 60% 40% at 20% 80%,
      rgba(74, 124, 89, 0.06) 0%,
      transparent 60%
    );
  }

  .event-bg-gradient-3 {
    background: radial-gradient(
      ellipse 50% 60% at 85% 40%,
      rgba(200, 168, 78, 0.04) 0%,
      transparent 50%
    );
    animation: event-bg-shift 12s ease-in-out infinite alternate;
  }

  @keyframes event-bg-shift {
    0% {
      opacity: 0.6;
      transform: scale(1);
    }
    100% {
      opacity: 1;
      transform: scale(1.05);
    }
  }

  .event-bg-grain {
    position: absolute;
    inset: 0;
    opacity: 0.025;
    background-image:
      radial-gradient(circle at 20% 30%, var(--color-gold) 0.5px, transparent 0.5px),
      radial-gradient(circle at 80% 70%, var(--color-gold) 0.5px, transparent 0.5px);
    background-size: 60px 60px;
  }

  @media (max-width: 768px) {
    .event-bg-gradient-1 {
      background: radial-gradient(
        ellipse 90% 60% at 50% 20%,
        rgba(200, 168, 78, 0.04) 0%,
        transparent 65%
      );
    }
  }
</style>
