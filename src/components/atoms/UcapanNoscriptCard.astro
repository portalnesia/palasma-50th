<style>
  .ucapan-noscript {
    position: relative;
    z-index: 5;
    text-align: center;
    padding: 2rem;
    color: var(--color-earth-sand);
    width: 100%;
    max-width: 600px;
    margin: 2rem auto 0;
  }

  .ucapan-noscript-card {
    background: rgba(12, 92, 179, 0.4);
    border: 1px solid rgba(200, 168, 78, 0.15);
    border-radius: 12px;
    padding: 2rem 1.5rem;
  }

  .ucapan-noscript-icon {
    width: 48px;
    height: 48px;
    color: var(--color-gold);
    margin-bottom: 1rem;
    opacity: 0.7;
  }

  .ucapan-noscript p {
    margin: 0.5rem 0;
    font-size: var(--text-body-sm);
  }

  .ucapan-noscript-hint {
    font-size: 0.8rem !important;
    opacity: 0.6;
  }
</style>
