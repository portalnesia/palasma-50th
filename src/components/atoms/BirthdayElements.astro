---

---

<div class="splash-decorations" aria-hidden="true">
  {/* Cake */}
  <div class="bday-cake">
    <svg viewBox="0 0 160 140" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="35" y="32" width="90" height="26" rx="5" fill="#c8a84e" opacity="0.85"></rect>
      <rect x="35" y="32" width="90" height="6" rx="3" fill="#e0c86a" opacity="0.5"></rect>
      <rect x="20" y="58" width="120" height="28" rx="5" fill="#a8882e" opacity="0.75"></rect>
      <rect x="20" y="58" width="120" height="6" rx="3" fill="#d4b886" opacity="0.4"></rect>
      <rect x="8" y="86" width="144" height="30" rx="5" fill="#8b6914" opacity="0.7"></rect>
      <rect x="8" y="86" width="144" height="6" rx="3" fill="#c8a84e" opacity="0.35"></rect>
      <ellipse cx="80" cy="122" rx="78" ry="10" fill="rgba(200,168,78,0.12)"></ellipse>
      <rect x="52" y="14" width="3" height="18" rx="1.5" fill="#d4b886"></rect>
      <ellipse cx="53.5" cy="12" rx="4" ry="6" fill="#e0c86a" opacity="0.9"></ellipse>
      <rect x="78" y="10" width="3" height="22" rx="1.5" fill="#c8a84e"></rect>
      <ellipse cx="79.5" cy="8" rx="4" ry="6" fill="#e0c86a" opacity="0.9"></ellipse>
      <rect x="104" y="14" width="3" height="18" rx="1.5" fill="#d4b886"></rect>
      <ellipse cx="105.5" cy="12" rx="4" ry="6" fill="#e0c86a" opacity="0.9"></ellipse>
    </svg>
  </div>

  {/* Balloons */}
  <div class="bday-balloon bday-balloon-1">
    <div class="bday-balloon-body" style="background:var(--color-gold);"></div>
    <div class="bday-balloon-string"></div>
  </div>
  <div class="bday-balloon bday-balloon-2">
    <div class="bday-balloon-body" style="background:var(--color-earth-moss-light);"></div>
    <div class="bday-balloon-string"></div>
  </div>
  <div class="bday-balloon bday-balloon-3">
    <div class="bday-balloon-body" style="background:var(--color-earth-sand);"></div>
    <div class="bday-balloon-string"></div>
  </div>
  <div class="bday-balloon bday-balloon-4">
    <div class="bday-balloon-body" style="background:var(--color-gold-light);"></div>
    <div class="bday-balloon-string"></div>
  </div>

  {/* Party hat */}
  <div class="bday-hat">
    <svg viewBox="0 0 60 80" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M30 5 L55 75 L5 75Z" fill="url(#hat-grad)" opacity="0.7"></path>
      <circle cx="30" cy="5" r="5" fill="#e0c86a" opacity="0.8"></circle>
      <line x1="18" y1="50" x2="42" y2="50" stroke="#e0c86a" stroke-width="1.5" opacity="0.3"
      ></line>
      <line x1="13" y1="62" x2="47" y2="62" stroke="#d4b886" stroke-width="1.5" opacity="0.25"
      ></line>
      <defs>
        <linearGradient id="hat-grad" x1="30" y1="5" x2="30" y2="75" gradientUnits="userSpaceOnUse">
          <stop offset="0%" stop-color="#c8a84e"></stop>
          <stop offset="100%" stop-color="#a8882e"></stop>
        </linearGradient>
      </defs>
    </svg>
  </div>

  {/* Gift box */}
  <div class="bday-gift">
    <svg viewBox="0 0 80 70" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="5" y="25" width="70" height="40" rx="4" fill="#a8882e" opacity="0.65"></rect>
      <rect x="5" y="25" width="70" height="12" rx="4" fill="#c8a84e" opacity="0.7"></rect>
      <rect x="36" y="25" width="8" height="40" fill="#e0c86a" opacity="0.35"></rect>
      <path d="M40 25 C40 15 25 10 20 18 C18 22 25 25 40 25Z" fill="#c8a84e" opacity="0.5"></path>
      <path d="M40 25 C40 15 55 10 60 18 C62 22 55 25 40 25Z" fill="#d4b886" opacity="0.5"></path>
    </svg>
  </div>

  {/* Confetti burst */}
  <div class="bday-confetti">
    <span class="bday-confetti-piece bday-cp-1"></span>
    <span class="bday-confetti-piece bday-cp-2"></span>
    <span class="bday-confetti-piece bday-cp-3"></span>
    <span class="bday-confetti-piece bday-cp-4"></span>
    <span class="bday-confetti-piece bday-cp-5"></span>
    <span class="bday-confetti-piece bday-cp-6"></span>
    <span class="bday-confetti-piece bday-cp-7"></span>
    <span class="bday-confetti-piece bday-cp-8"></span>
    <span class="bday-confetti-piece bday-cp-9"></span>
    <span class="bday-confetti-piece bday-cp-10"></span>
    <span class="bday-confetti-piece bday-cp-11"></span>
    <span class="bday-confetti-piece bday-cp-12"></span>
  </div>
</div>

<style>
  .splash-decorations {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1; /* Positioned behind the main content (z-index: 10) */
    overflow: hidden;
  }

  /* Cake */
  .bday-cake {
    position: absolute;
    left: 50%;
    bottom: 20px;
    transform: translateX(-50%);
    width: 150px;
    opacity: 0.2;
  }

  /* Balloons */
  .bday-balloon {
    position: absolute;
    bottom: 70px;
    opacity: 0.15;
  }

  .bday-balloon-body {
    width: 40px;
    height: 52px;
    border-radius: 50% 50% 50% 50% / 55% 55% 45% 45%;
    position: relative;
  }

  .bday-balloon-body::after {
    content: "";
    position: absolute;
    bottom: -6px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 7px solid inherit;
  }

  .bday-balloon-string {
    width: 1px;
    height: 40px;
    margin: 0 auto;
    background: linear-gradient(to bottom, rgba(200, 168, 78, 0.4), transparent);
  }

  .bday-balloon-1 {
    left: 10%;
    bottom: 60px;
  }
  .bday-balloon-2 {
    left: 25%;
    bottom: 120px;
  }
  .bday-balloon-3 {
    right: 20%;
    bottom: 130px;
  }
  .bday-balloon-4 {
    right: 8%;
    bottom: 80px;
  }

  /* Party hat */
  .bday-hat {
    position: absolute;
    right: 15%;
    bottom: 30px;
    width: 50px;
    opacity: 0.15;
    transform: rotate(-12deg);
  }

  /* Gift box */
  .bday-gift {
    position: absolute;
    left: 12%;
    bottom: 30px;
    width: 70px;
    opacity: 0.15;
  }

  /* Confetti burst */
  .bday-confetti {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .bday-confetti-piece {
    position: absolute;
    width: 8px;
    height: 4px;
    border-radius: 1px;
    opacity: 0;
    bottom: -20px;
  }

  .bday-cp-1 {
    background: var(--color-gold);
    left: 15%;
  }
  .bday-cp-2 {
    background: var(--color-earth-sand);
    left: 25%;
    width: 6px;
    height: 3px;
  }
  .bday-cp-3 {
    background: var(--color-earth-moss);
    left: 35%;
  }
  .bday-cp-4 {
    background: var(--color-gold-light);
    left: 45%;
    width: 7px;
    height: 3px;
  }
  .bday-cp-5 {
    background: var(--color-gold);
    left: 55%;
  }
  .bday-cp-6 {
    background: var(--color-earth-moss-light);
    left: 65%;
    width: 5px;
  }
  .bday-cp-7 {
    background: var(--color-earth-sand);
    left: 75%;
    width: 6px;
    height: 3px;
  }
  .bday-cp-8 {
    background: var(--color-gold-light);
    left: 85%;
  }
  .bday-cp-9 {
    background: var(--color-earth-moss);
    left: 20%;
    width: 5px;
    height: 3px;
  }
  .bday-cp-10 {
    background: var(--color-gold);
    left: 50%;
    width: 7px;
  }
  .bday-cp-11 {
    background: var(--color-earth-sand);
    left: 40%;
    width: 6px;
    height: 3px;
  }
  .bday-cp-12 {
    background: var(--color-gold-light);
    left: 70%;
  }
</style>
