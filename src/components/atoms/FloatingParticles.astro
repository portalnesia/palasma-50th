---
interface Props {
  prefix?: string;
  count?: number;
}

const { prefix = "event", count } = Astro.props;

const allParticles = [
  { size: 7, left: 10, top: 15, duration: 8, delay: 0 },
  { size: 4, left: 25, top: 70, duration: 10, delay: 1.5 },
  { size: 8, left: 75, top: 20, duration: 7, delay: 0.8 },
  { size: 3, left: 85, top: 60, duration: 9, delay: 2.2 },
  { size: 5, left: 50, top: 85, duration: 11, delay: 3 },
  { size: 4, left: 15, top: 45, duration: 8.5, delay: 4 },
  { size: 6, left: 65, top: 10, duration: 9.5, delay: 1 },
  { size: 3, left: 40, top: 35, duration: 7.5, delay: 5 },
  { size: 5, left: 20, top: 30, duration: 9, delay: 0.5 },
  { size: 6, left: 70, top: 80, duration: 12, delay: 2 },
  { size: 4, left: 45, top: 55, duration: 10, delay: 1 },
  { size: 5, left: 80, top: 50, duration: 8, delay: 3.5 },
  { size: 7, left: 30, top: 25, duration: 11, delay: 2.5 },
  { size: 3, left: 90, top: 15, duration: 7, delay: 4.5 },
];

let particleCount = allParticles.length;
if (count !== undefined) {
  particleCount = count;
} else if (prefix === "twibbon") {
  particleCount = 6;
} else if (prefix === "ucapan") {
  particleCount = 8;
}

const particles = allParticles.slice(0, particleCount);
---

<div class:list={[`${prefix}-particles`]} aria-hidden="true">
  {
    particles.map(({ size, left, top, duration, delay }, i) => (
      <span
        class:list={[`${prefix}-particle`, `${prefix}-particle-${i + 1}`]}
        style={`left: ${left}%; top: ${top}%; width: ${size}px; height: ${size}px; animation-duration: ${duration}s; animation-delay: ${delay}s;`}
      />
    ))
  }
</div>

<style>
  .event-particles,
  .sambutan-particles,
  .ucapan-particles,
  .twibbon-particles,
  .absensi-particles {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    overflow: hidden;
  }

  .event-particle,
  .sambutan-particle,
  .ucapan-particle,
  .twibbon-particle,
  .absensi-particle {
    position: absolute;
    border-radius: 50%;
    background: var(--color-gold);
    opacity: 0;
    animation: fp-float linear infinite;
  }

  @keyframes fp-float {
    0% {
      opacity: 0;
      transform: translateY(0) scale(1);
    }
    15% {
      opacity: 0.5;
    }
    50% {
      opacity: 0.3;
    }
    85% {
      opacity: 0.5;
    }
    100% {
      opacity: 0;
      transform: translateY(-80px) scale(0.5);
    }
  }
</style>
