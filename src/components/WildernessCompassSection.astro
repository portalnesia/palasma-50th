    max-width: 500px;
    margin: 0 auto 1.5rem;
  }

  /* Autoplay thin linear gold progress bar */
  .autoplay-progress-container {
    width: calc(100% - 40px);
    margin: 0 auto 1.5rem;
    height: 2px;
    background: rgba(212, 175, 55, 0.12);
    border-radius: 2px;
