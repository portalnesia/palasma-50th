  }

  .autoplay-progress-bar {
    width: 0%;
    height: 100%;
    background: linear-gradient(90deg, #aa841c, #d4af37, #f5e6c8);
    will-change: width;
  }

  .lantern-viewport {
    width: 100%;
    overflow: hidden;
    cursor: grab;
