---
import { ASSETS } from "@config/assets.ts";
import SectionTitle from "@components/atoms/SectionTitle.astro";
import OrnamentFlourish from "@components/atoms/OrnamentFlourish.astro";
import SideDecor from "@components/atoms/SideDecor.astro";
import FloatingParticles from "@components/atoms/FloatingParticles.astro";

interface Props {
  useBg?: boolean;
}

const { useBg = false } = Astro.props;
const allPhotos = ASSETS.gallery || [];

// 7 Milestone Data matching the 7 photos
const milestones = [
  {
    index: 0,
    name: "Gerbang Rimba",
    subName: "Sembalun Starting Point",
    altitude: 1156,
    coords: "8°21'15\" S, 116°26'10\" E",
    temp: "22°C",
    desc: "Perjalanan dimulai di padang rumput savanna yang membentang tak berujung. Angin berhembus membawa aroma tanah basah dan petualangan yang menanti di ufuk timur Rinjani.",
    photo: allPhotos[0] || { src: "", caption: "" },
    caption: "Momen kebersamaan di tengah petualangan alam bebas.",
  },
  {
    index: 1,
    name: "Savana Emas",
    subName: "Pos 2 Tenengean",
    altitude: 1500,
    coords: "8°22'05\" S, 116°25'40\" E",
    temp: "26°C",
    desc: "Langkah kaki berderap di antara ilalang emas setinggi dada. Di kejauhan, bayangan megah Gunung Rinjani tampak kokoh menyapa jiwa-jiwa petualang PALASMA.",
    photo: allPhotos[1] || { src: "", caption: "" },
    caption: "Menembus batas, menapaki puncak-puncak tertinggi.",
  },
  {
    index: 2,
    name: "Cemara Tunggal",
    subName: "Tanjakan Penyesalan",
    altitude: 1800,
    coords: "8°23'10\" S, 116°25'12\" E",
    temp: "20°C",
    desc: "Keringat bercucuran membasahi bumi, napas terengah di setiap tanjakan terjal berdebu. Namun di sinilah tekad baja ditempa dan persaudaraan sejati diuji.",
    photo: allPhotos[2] || { src: "", caption: "" },
    caption: "",
  },
  {
    index: 3,
    name: "Plawangan Camp",
    subName: "Campsite Kawah",
    altitude: 2639,
    coords: "8°24'30\" S, 116°24'45\" E",
    temp: "14°C",
    desc: "Tenda-tenda berdiri kokoh di tepi kawah. Kabut malam turun perlahan menemani kehangatan api unggun, sementara di atas kepala, rasi bintang berkilau begitu dekat.",
    photo: allPhotos[3] || { src: "", caption: "" },
    caption: "",
  },
  {
    index: 4,
    name: "Segara Anak",
    subName: "Danau Vulkanik",
    altitude: 2008,
    coords: "8°25'15\" S, 116°24'02\" E",
    temp: "16°C",
    desc: "Turun ke dasar kawah menuju riak air biru jernih. Tempat membasuh lelah pendakian, memancing ikan mas liar, dan merasakan keagungan kawah purba yang tenang.",
    photo: allPhotos[4] || { src: "", caption: "" },
    caption: "",
  },
  {
    index: 5,
    name: "Letter U",
    subName: "Jalur Pasir Summit",
    altitude: 3200,
    coords: "8°25'45\" S, 116°24'15\" E",
    temp: "9°C",
    desc: "Subuh dingin mencubit kulit. Berjalan merayap di atas pasir berkerikil tajam, selangkah naik setengah merosot, berkejaran dengan fajar yang mulai menyembul.",
    photo: allPhotos[5] || { src: "", caption: "" },
    caption: "",
  },
  {
    index: 6,
    name: "Puncak Rinjani",
    subName: "Summit of Lombok 3,726m",
    altitude: 3726,
    coords: "8°25'50\" S, 116°24'20\" E",
    temp: "4°C",
    desc: "Berdiri tegak di titik tertinggi. Air mata haru menetes saat mentari pagi memancarkan cahaya keemasan ke seluruh kawah dan samudera awan Nusantara. Kami sampai!",
    photo: allPhotos[6] || { src: "", caption: "" },
    caption: "",
  },
];
---

<section id="wilderness-lanterns" class="lanterns-section">
  {/* ── Background layers ──────────────────────────────────── */}
  <div
    class:list={["lanterns-bg", { "has-bg-image": useBg }]}
    aria-hidden="true"
    style={useBg ? `--bg-url: url(${ASSETS.bg[7]})` : undefined}
  >
    <div class="lanterns-bg-gradient"></div>
    <div class="lanterns-bg-grain"></div>
    <div class="lanterns-forest-silhouette"></div>
  </div>

  {/* ── Floating Firefly Particles ────────────────────────── */}
  <FloatingParticles prefix="lanterns" count={14} />

  {/* ── Side decorations ───────────────────────────────────── */}
  <SideDecor position="left" />
  <SideDecor position="right" />

  <div class="lanterns-container">
    {/* ── Top flourish ───────────────────────────────────────── */}
    <OrnamentFlourish position="top" />

    {/* ── Title ──────────────────────────────────────────────── */}
    <SectionTitle text="Lentera Hutan" />

    {/* ── Subtitle ──────────────────────────────────────────── */}
    <p class="lanterns-subtitle reveal-on-scroll reveal-fade-up" style="transition-delay: 100ms;">
      Kenangan hangat yang menggantung indah di bawah keteduhan rimba raya
    </p>

    {/* ── Divider ────────────────────────────────────────────── */}
    <div
      class="lanterns-divider reveal-on-scroll reveal-fade-up"
      style="transition-delay: 150ms;"
      aria-hidden="true"
    >
      <span class="lanterns-divider-line"></span>
      <span class="lanterns-divider-diamond">◆</span>
      <span class="lanterns-divider-line"></span>
    </div>

    {/* ── Ambient Night Soundscape Controller ────────────────── */}
    <div
      class="soundscape-control reveal-on-scroll reveal-fade-up"
      style="transition-delay: 180ms;"
    >
      <button
        type="button"
        id="lanterns-sound-toggle"
        class="sound-toggle-btn"
        aria-label="Aktifkan Dengung Malam"
      >
        <span class="sound-icon-wrapper">
          <svg
            class="sound-icon-play"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
            <path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path>
          </svg>
          <svg
            class="sound-icon-mute hidden"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
            <line x1="23" y1="9" x2="17" y2="15"></line>
            <line x1="17" y1="9" x2="23" y2="15"></line>
          </svg>
        </span>
        <span class="sound-btn-text">Dengung Malam Off</span>
      </button>

      <div class="sound-visualizer">
        <span class="bar bar-1"></span>
        <span class="bar bar-2"></span>
        <span class="bar bar-3"></span>
        <span class="bar bar-4"></span>
        <span class="bar bar-5"></span>
      </div>
    </div>

    {/* ── AUTOMATIC HANGING LANTERN CAROUSEL ─────────────────── */}
    <div class="carousel-wrapper reveal-on-scroll reveal-scale-in" style="transition-delay: 200ms;">
      {/* Golden progress bar reflecting autoplay timer */}
      <div class="autoplay-progress-container" aria-hidden="true">
        <div class="autoplay-progress-bar" id="lantern-timer-progress"></div>
      </div>

      {/* Manual slide controllers */}
      <button
        type="button"
        class="ctrl-arrow prev"
        id="lantern-prev-btn"
        aria-label="Lentera sebelumnya"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button
        type="button"
        class="ctrl-arrow next"
        id="lantern-next-btn"
        aria-label="Lentera selanjutnya"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>

      {/* Slide viewport */}
      <div class="lantern-viewport" id="wilderness-lantern-viewport">
        <div class="lantern-track" id="wilderness-lantern-track">
          {
            milestones.map((ms) => (
              <div class:list={["lantern-slide", { active: ms.index === 0 }]} data-index={ms.index}>
                {/* Thin golden chain hanging the card */}
                <div class="lantern-chain" aria-hidden="true">
                  <svg width="6" height="60" viewBox="0 0 6 60" fill="none">
                    <line
                      x1="3"
                      y1="0"
                      x2="3"
                      y2="60"
                      stroke="#d4af37"
                      stroke-width="1.5"
                      stroke-dasharray="2 3"
                    />
                    <circle cx="3" cy="58" r="2" fill="#d4af37" />
                  </svg>
                </div>

                <div class="lantern-card">
                  {/* Gold brass top cap */}
                  <div class="lantern-cap top-cap" aria-hidden="true">
                    <span class="cap-bracket" />
                  </div>

                  <div class="lantern-glass">
                    {ms.photo.src ? (
                      <img src={ms.photo.src} alt={ms.name} class="lantern-img" loading="lazy" />
                    ) : (
                      <div class="lantern-img-placeholder">
                        <span>✨</span>
                      </div>
                    )}

                    {/* Warm Candle Light overlay filtering the photo */}
                    <div class="lantern-candle-glow" />
                    {/* Glass glare highlight */}
                    <div class="lantern-reflection" />
                  </div>

                  {/* Gold brass bottom cap */}
                  <div class="lantern-cap bottom-cap" aria-hidden="true" />

                  {/* Photo Title Overlay */}
                  <div class="lantern-title-overlay">
                    <span class="lantern-index">#0{ms.index + 1}</span>
                    <h4 class="lantern-name">{ms.name}</h4>
                  </div>

                  {/* Zoom shutter trigger button */}
                  <button
                    type="button"
                    class="lantern-zoom-btn"
                    data-index={ms.index}
                    aria-label="Perbesar Lentera Kenangan"
                  >
                    <svg
                      width="18"
                      height="18"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <circle cx="11" cy="11" r="8" />
                      <line x1="21" y1="21" x2="16.65" y2="16.65" />
                      <line x1="11" y1="8" x2="11" y2="14" />
                      <line x1="8" y1="11" x2="14" y2="11" />
                    </svg>
                  </button>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    {/* ── Carousel Dot Indicators ────────────────────────────── */}
    <div
      class="lantern-dots-strip reveal-on-scroll reveal-fade-up"
      style="transition-delay: 240ms;"
    >
      {
        milestones.map((ms) => (
          <button
            type="button"
            class:list={["lantern-dot", { active: ms.index === 0 }]}
            data-index={ms.index}
            aria-label={`Lihat lentera ${ms.index + 1}`}
          />
        ))
      }
    </div>

    {/* ── LUXURY LEATHER LOGBOOK (Explorer's Journal) ─────────── */}
    <div class="logbook-viewport reveal-on-scroll reveal-fade-up" style="transition-delay: 280ms;">
      <div class="logbook-container">
        {/* Leather texture bindings */}
        <div class="logbook-binder" aria-hidden="true">
          <span class="binder-ring"></span>
          <span class="binder-ring"></span>
          <span class="binder-ring"></span>
        </div>

        <div class="logbook-page">
          <div class="logbook-header">
            <div class="logbook-stat">
              <span class="stat-lbl">ELEVASI</span>
              <div class="stat-val-group">
                <span class="stat-val" id="log-alt-num">1156</span>
                <span class="stat-unit">mdpl</span>
              </div>
            </div>

            <div class="logbook-stat">
              <span class="stat-lbl">TEMPERATUR</span>
              <span class="stat-val text-emerald-400" id="log-temp-val">22°C</span>
            </div>

            <div class="logbook-stat">
              <span class="stat-lbl">KOORDINAT</span>
              <span class="stat-val text-amber-300 font-mono text-xs" id="log-coords-val"
                >8°21'15" S, 116°26'10" E</span
              >
            </div>
          </div>

          <div class="logbook-content">
            <h3 class="logbook-title" id="log-title-text">Gerbang Rimba</h3>
            <span class="logbook-subtitle" id="log-subtitle-text">Sembalun Starting Point</span>
            <p class="logbook-description" id="log-desc-text">
              Perjalanan dimulai di padang rumput savanna yang membentang tak berujung. Angin
              berhembus membawa aroma tanah basah dan petualangan yang menanti di ufuk timur
              Rinjani.
            </p>
          </div>

          {/* Caption banner quote */}
          <div class="logbook-caption" id="log-caption-banner">
            <span class="quote-sign">“</span>
            <span class="quote-text" id="log-caption-text"
              >Momen kebersamaan di tengah petualangan alam bebas.</span
            >
          </div>
        </div>
      </div>
    </div>

    {/* ── Bottom flourish ────────────────────────────────────── */}
    <OrnamentFlourish position="bottom" />
  </div>

  {/* ── Shutter Lightbox Modal ────────────────────────────── */}
  <dialog id="lanterns-lightbox" class="w-lightbox-modal" aria-label="Tampilan Lentera Fullscreen">
    <div class="w-lightbox-backdrop" id="w-lightbox-backdrop"></div>
    <div class="w-lightbox-content">
      <button
        type="button"
        id="w-lightbox-close"
        class="w-lightbox-close-btn"
        aria-label="Tutup Lentera"
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>

      <button
        type="button"
        id="w-lightbox-prev"
        class="w-lightbox-nav-btn w-lightbox-prev-btn"
        aria-label="Sebelumnya"
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <div class="w-lightbox-frame">
        {/* Shutter Blades overlay effect */}
        <div class="shutter-blades" id="w-shutter-blades">
          <span class="blade"></span><span class="blade"></span>
          <span class="blade"></span><span class="blade"></span>
        </div>

        <div class="w-lightbox-lens-ring">
          <img id="w-lightbox-image" src="" alt="Lentera Kenangan" class="w-lightbox-image" />
          <div class="w-lightbox-glass-glare"></div>
        </div>

        <div class="w-lightbox-details">
          <h4 id="w-lightbox-title" class="w-lightbox-title-text">Gerbang Rimba</h4>
          <p id="w-lightbox-coords" class="w-lightbox-coords-text">8°21'15" S, 116°26'10" E</p>
          <p id="w-lightbox-desc" class="w-lightbox-desc-text"></p>
          <div id="w-lightbox-caption-box" class="w-lightbox-caption-box hidden">
            <p id="w-lightbox-caption" class="w-lightbox-caption-text"></p>
          </div>
        </div>
      </div>

      <button
        type="button"
        id="w-lightbox-next"
        class="w-lightbox-nav-btn w-lightbox-next-btn"
        aria-label="Selanjutnya"
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>
  </dialog>
</section>

<script>
  (function () {
    "use strict";

    // ── Web Audio API Synthesizer (Forest Ambient Sound) ──
    class ForestSynth {
      private ctx: AudioContext | null = null;
      public isPlaying: boolean = false;
      private masterGain: GainNode | null = null;
      private windNoise: AudioBufferSourceNode | null = null;
      private windFilter: BiquadFilterNode | null = null;
      private windLFO: OscillatorNode | null = null;
      private fireHiss: AudioBufferSourceNode | null = null;
      private fireFilter: BiquadFilterNode | null = null;
      private fireInterval: any = null;
      private cricketInterval: any = null;

      start() {
        if (this.isPlaying) return;
        const AudioContextClass = window.AudioContext || (window as any).webkitAudioContext;
        if (!AudioContextClass) return;

        this.ctx = new AudioContextClass();
        this.masterGain = this.ctx.createGain();
        this.masterGain.gain.setValueAtTime(0, this.ctx.currentTime);
        this.masterGain.connect(this.ctx.destination);
        this.masterGain.gain.linearRampToValueAtTime(0.5, this.ctx.currentTime + 1.5);

        this.initWind();
        this.initCampfire();
        this.initCrickets();
        this.isPlaying = true;
      }

      stop() {
        if (!this.isPlaying || !this.ctx) return;
        const stopTime = this.ctx.currentTime + 0.8;
        this.masterGain?.gain.linearRampToValueAtTime(0, stopTime);

        const currentLFO = this.windLFO;
        const currentWind = this.windNoise;
        const currentHiss = this.fireHiss;
        const currentCtx = this.ctx;

        clearInterval(this.fireInterval);
        clearInterval(this.cricketInterval);

        setTimeout(() => {
          try {
            currentLFO?.stop();
            currentWind?.stop();
            currentHiss?.stop();
            if (currentCtx && currentCtx.state !== "closed") {
              currentCtx.close();
            }
          } catch (e) {}
        }, 1000);
        this.isPlaying = false;
      }

      private createNoiseBuffer(): AudioBuffer {
        const sampleRate = this.ctx!.sampleRate;
        const bufferSize = 2 * sampleRate;
        const noiseBuffer = this.ctx!.createBuffer(1, bufferSize, sampleRate);
        const output = noiseBuffer.getChannelData(0);
        for (let i = 0; i < bufferSize; i++) {
          output[i] = Math.random() * 2 - 1;
        }
        return noiseBuffer;
      }

      private initWind() {
        if (!this.ctx || !this.masterGain) return;
        this.windNoise = this.ctx.createBufferSource();
        this.windNoise.buffer = this.createNoiseBuffer();
        this.windNoise.loop = true;

        this.windFilter = this.ctx.createBiquadFilter();
        this.windFilter.type = "lowpass";
        this.windFilter.frequency.setValueAtTime(280, this.ctx.currentTime);
        this.windFilter.Q.setValueAtTime(1.0, this.ctx.currentTime);

        const windGain = this.ctx.createGain();
        windGain.gain.setValueAtTime(0.18, this.ctx.currentTime);

        this.windLFO = this.ctx.createOscillator();
        this.windLFO.frequency.setValueAtTime(0.04, this.ctx.currentTime);

        const lfoGain = this.ctx.createGain();
        lfoGain.gain.setValueAtTime(150, this.ctx.currentTime);

        this.windLFO.connect(lfoGain);
        lfoGain.connect(this.windFilter.frequency);

        this.windNoise.connect(this.windFilter);
        this.windFilter.connect(windGain);
        windGain.connect(this.masterGain);

        this.windLFO.start();
        this.windNoise.start();
      }

      private initCampfire() {
        if (!this.ctx || !this.masterGain) return;
        this.fireHiss = this.ctx.createBufferSource();
        this.fireHiss.buffer = this.createNoiseBuffer();
        this.fireHiss.loop = true;

        this.fireFilter = this.ctx.createBiquadFilter();
        this.fireFilter.type = "bandpass";
        this.fireFilter.frequency.setValueAtTime(320, this.ctx.currentTime);
        this.fireFilter.Q.setValueAtTime(1.2, this.ctx.currentTime);

        const hissGain = this.ctx.createGain();
        hissGain.gain.setValueAtTime(0.05, this.ctx.currentTime);

        this.fireHiss.connect(this.fireFilter);
        this.fireFilter.connect(hissGain);
        hissGain.connect(this.masterGain);
        this.fireHiss.start();

        const hissLFO = this.ctx.createOscillator();
        hissLFO.frequency.setValueAtTime(1.8, this.ctx.currentTime);
        const hissLFOGain = this.ctx.createGain();
        hissLFOGain.gain.setValueAtTime(0.015, this.ctx.currentTime);
        hissLFO.connect(hissLFOGain);
        hissLFOGain.connect(hissGain.gain);
        hissLFO.start();

        this.fireInterval = setInterval(() => {
          if (this.isPlaying && Math.random() > 0.45) {
            this.playPop();
          }
        }, 140);
      }

      private playPop() {
        if (!this.ctx || !this.masterGain) return;
        const osc = this.ctx.createOscillator();
        const gain = this.ctx.createGain();
        const filter = this.ctx.createBiquadFilter();

        osc.type = "sine";
        const startFreq = 700 + Math.random() * 1100;
        osc.frequency.setValueAtTime(startFreq, this.ctx.currentTime);
        osc.frequency.exponentialRampToValueAtTime(80, this.ctx.currentTime + 0.012);

        filter.type = "highpass";
        filter.frequency.setValueAtTime(550, this.ctx.currentTime);

        gain.gain.setValueAtTime(0.04 + Math.random() * 0.1, this.ctx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.001, this.ctx.currentTime + 0.012);

        osc.connect(filter);
        filter.connect(gain);
        gain.connect(this.masterGain);

        osc.start();
        osc.stop(this.ctx.currentTime + 0.018);
      }

      private initCrickets() {
        this.cricketInterval = setInterval(() => {
          if (this.isPlaying && Math.random() > 0.3) {
            this.playCricketChirp();
          }
        }, 1800);
      }

      private playCricketChirp() {
        if (!this.ctx || !this.masterGain) return;
        const time = this.ctx.currentTime;
        const pulseCount = 3 + Math.floor(Math.random() * 2);
        const pulseLen = 0.012;
        const pulseSpacing = 0.03;

        for (let i = 0; i < pulseCount; i++) {
          const osc = this.ctx.createOscillator();
          const gain = this.ctx.createGain();

          osc.type = "sine";
          osc.frequency.setValueAtTime(4100 + Math.random() * 80, time + i * pulseSpacing);

          const pStart = time + i * pulseSpacing;
          gain.gain.setValueAtTime(0, pStart);
          gain.gain.linearRampToValueAtTime(0.004, pStart + 0.002);
          gain.gain.setValueAtTime(0.004, pStart + pulseLen - 0.002);
          gain.gain.linearRampToValueAtTime(0, pStart + pulseLen);

          osc.connect(gain);
          gain.connect(this.masterGain);

          osc.start(pStart);
          osc.stop(pStart + pulseLen + 0.003);
        }
      }
    }

    // Initialize Forest Synth
    const synth = new ForestSynth();
    const soundToggleBtn = document.getElementById("lanterns-sound-toggle");
    const soundBtnText = soundToggleBtn?.querySelector(".sound-btn-text");
    const visualizer = document.querySelector(".sound-visualizer");
    const iconPlay = soundToggleBtn?.querySelector(".sound-icon-play");
    const iconMute = soundToggleBtn?.querySelector(".sound-icon-mute");

    soundToggleBtn?.addEventListener("click", () => {
      if (!synth.isPlaying) {
        synth.start();
        soundToggleBtn.classList.add("playing");
        if (soundBtnText) soundBtnText.textContent = "Dengung Malam On";
        visualizer?.classList.add("active");
        iconPlay?.classList.add("hidden");
        iconMute?.classList.remove("hidden");
      } else {
        synth.stop();
        soundToggleBtn.classList.remove("playing");
        if (soundBtnText) soundBtnText.textContent = "Dengung Malam Off";
        visualizer?.classList.remove("active");
        iconPlay?.classList.remove("hidden");
        iconMute?.classList.add("hidden");
      }
    });

    // ── Milestone Registry ──
    const milestoneData = [
      {
        index: 0,
        name: "Gerbang Rimba",
        subName: "Sembalun Starting Point",
        altitude: 1156,
        coords: "8°21'15\" S, 116°26'10\" E",
        temp: "22°C",
        desc: "Perjalanan dimulai di padang rumput savanna yang membentang tak berujung. Angin berhembus membawa aroma tanah basah dan petualangan yang menanti di ufuk timur Rinjani.",
        caption: "Momen kebersamaan di tengah petualangan alam bebas.",
      },
      {
        index: 1,
        name: "Savana Emas",
        subName: "Pos 2 Tenengean",
        altitude: 1500,
        coords: "8°22'05\" S, 116°25'40\" E",
        temp: "26°C",
        desc: "Langkah kaki berderap di antara ilalang emas setinggi dada. Di kejauhan, bayangan megah Gunung Rinjani tampak kokoh menyapa jiwa-jiwa petualang PALASMA.",
        caption: "Menembus batas, menapaki puncak-puncak tertinggi.",
      },
      {
        index: 2,
        name: "Cemara Tunggal",
        subName: "Tanjakan Penyesalan",
        altitude: 1800,
        coords: "8°23'10\" S, 116°25'12\" E",
        temp: "20°C",
        desc: "Keringat bercucuran membasahi bumi, napas terengah di setiap tanjakan terjal berdebu. Namun di sinilah tekad baja ditempa dan persaudaraan sejati diuji.",
        caption: "",
      },
      {
        index: 3,
        name: "Plawangan Camp",
        subName: "Campsite Kawah",
        altitude: 2639,
        coords: "8°24'30\" S, 116°24'45\" E",
        temp: "14°C",
        desc: "Tenda-tenda berdiri kokoh di tepi kawah. Kabut malam turun perlahan menemani kehangatan api unggun, sementara di atas kepala, rasi bintang berkilau begitu dekat.",
        caption: "",
      },
      {
        index: 4,
        name: "Segara Anak",
        subName: "Danau Vulkanik",
        altitude: 2008,
        coords: "8°25'15\" S, 116°24'02\" E",
        temp: "16°C",
        desc: "Turun ke dasar kawah menuju riak air biru jernih. Tempat membasuh lelah pendakian, memancing ikan mas liar, dan merasakan keagungan kawah purba yang tenang.",
        caption: "",
      },
      {
        index: 5,
        name: "Letter U",
        subName: "Jalur Pasir Summit",
        altitude: 3200,
        coords: "8°25'45\" S, 116°24'15\" E",
        temp: "9°C",
        desc: "Subuh dingin mencubit kulit. Berjalan merayap di atas pasir berkerikil tajam, selangkah naik setengah merosot, berkejaran dengan fajar yang mulai menyembul.",
        caption: "",
      },
      {
        index: 6,
        name: "Puncak Rinjani",
        subName: "Summit of Lombok 3,726m",
        altitude: 3726,
        coords: "8°25'50\" S, 116°24'20\" E",
        temp: "4°C",
        desc: "Berdiri tegak di titik tertinggi. Air mata haru menetes saat mentari pagi memancarkan cahaya keemasan ke seluruh kawah dan samudera awan Nusantara. Kami sampai!",
        caption: "",
      },
    ];

    // ── Carousel Elements ──
    const viewport = document.getElementById("wilderness-lantern-viewport");
    const track = document.getElementById("wilderness-lantern-track") as HTMLDivElement;
    const slides = document.querySelectorAll(".lantern-slide") as NodeListOf<HTMLDivElement>;
    const dots = document.querySelectorAll(".lantern-dot") as NodeListOf<HTMLButtonElement>;
    const timerProgress = document.getElementById("lantern-timer-progress") as HTMLDivElement;

    const prevBtn = document.getElementById("lantern-prev-btn");
    const nextBtn = document.getElementById("lantern-next-btn");

    // Logbook Refs
    const altNum = document.getElementById("log-alt-num");
    const tempVal = document.getElementById("log-temp-val");
    const coordsVal = document.getElementById("log-coords-val");
    const titleText = document.getElementById("log-title-text");
    const subTitleText = document.getElementById("log-subtitle-text");
    const descText = document.getElementById("log-desc-text");
    const captionBanner = document.getElementById("log-caption-banner");
    const captionText = document.getElementById("log-caption-text");

    if (!track || !slides.length || !viewport) return;

    let activeIdx = 0;
    let currentAltitude = 1156;
    let altAnimId: any = null;

    // Autoplay Timer Loop variables
    const slideDuration = 4500; // 4.5s
    let lastTime = performance.now();
    let accumulatedTime = 0;
    let isPaused = false;
    let userInteractionTimer: any = null;

    // Gesture variables
    let startX = 0;
    let currentTranslate = 0;
    let prevTranslate = 0;
    let isDragging = false;

    // ── Altitude Odometer Animate ──
    function animateAltitude(targetAlt: number) {
      if (altAnimId) cancelAnimationFrame(altAnimId);
      const startAlt = currentAltitude;
      const diff = targetAlt - startAlt;
      const duration = 650;
      const startTime = performance.now();

      function update(now: number) {
        const elapsed = now - startTime;
        const progress = Math.min(elapsed / duration, 1);
        const ease = 1 - Math.pow(1 - progress, 3);
        const value = Math.round(startAlt + diff * ease);

        if (altNum) altNum.textContent = value.toString();

        if (progress < 1) {
          altAnimId = requestAnimationFrame(update);
        } else {
          currentAltitude = targetAlt;
          if (altNum) altNum.textContent = targetAlt.toString();
        }
      }
      altAnimId = requestAnimationFrame(update);
    }

    // ── Update Slider Position & State ──
    function updateSlider(idx: number, animate: boolean = true) {
      if (idx < 0 || idx >= milestoneData.length) return;
      activeIdx = idx;
      const data = milestoneData[activeIdx];

      // 1. Update slide active classes
      slides.forEach((slide, i) => {
        slide.classList.toggle("active", i === activeIdx);
      });

      // 2. Translate Track
      if (animate) {
        track.style.transition = "transform 0.6s cubic-bezier(0.25, 1, 0.5, 1)";
      } else {
        track.style.transition = "none";
      }

      const slideWidth = slides[0].offsetWidth;
      currentTranslate = -activeIdx * slideWidth;
      prevTranslate = currentTranslate;
      track.style.transform = `translateX(${currentTranslate}px)`;

      // 3. Update Dots active class
      dots.forEach((dot, i) => {
        dot.classList.toggle("active", i === activeIdx);
      });

      // 4. Update Logbook
      animateAltitude(data.altitude);
      if (tempVal) tempVal.textContent = data.temp;
      if (coordsVal) coordsVal.textContent = data.coords;
      if (titleText) titleText.textContent = data.name;
      if (subTitleText) subTitleText.textContent = data.subName;
      if (descText) descText.textContent = data.desc;

      // Caption banner toggle
      if (captionBanner && captionText) {
        if (data.caption) {
          captionText.textContent = data.caption;
          captionBanner.classList.remove("hidden");
        } else {
          captionBanner.classList.add("hidden");
        }
      }

      // Reset autoplay progress counter on slide shift
      accumulatedTime = 0;
      if (timerProgress) timerProgress.style.width = "0%";
    }

    function showNext() {
      const next = (activeIdx + 1) % milestoneData.length;
      updateSlider(next);
    }

    function showPrev() {
      const prev = (activeIdx - 1 + milestoneData.length) % milestoneData.length;
      updateSlider(prev);
    }

    // Controls click
    prevBtn?.addEventListener("click", () => {
      showPrev();
      resetUserTimer();
    });

    nextBtn?.addEventListener("click", () => {
      showNext();
      resetUserTimer();
    });

    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => {
        updateSlider(i);
        resetUserTimer();
      });
    });

    // ── AUTOPLAY LOOP (requestAnimationFrame) ──
    function autoPlayTick(now: number) {
      if (isDragging) {
        lastTime = now;
        requestAnimationFrame(autoPlayTick);
        return;
      }

      const delta = now - lastTime;
      lastTime = now;

      if (!isPaused) {
        accumulatedTime += delta;
        const progressPct = Math.min((accumulatedTime / slideDuration) * 100, 100);
        if (timerProgress) {
          timerProgress.style.width = `${progressPct}%`;
        }

        if (accumulatedTime >= slideDuration) {
          accumulatedTime = 0;
          showNext();
        }
      }

      requestAnimationFrame(autoPlayTick);
    }

    // Pause on Hover (Desktop)
    viewport.addEventListener("mouseenter", () => {
      isPaused = true;
    });
    viewport.addEventListener("mouseleave", () => {
      isPaused = false;
      lastTime = performance.now();
    });

    // Pause on Touch (Mobile)
    viewport.addEventListener(
      "touchstart",
      () => {
        isPaused = true;
      },
      { passive: true },
    );
    viewport.addEventListener(
      "touchend",
      () => {
        resetUserTimer();
      },
      { passive: true },
    );

    // Reset loop timer after user clicks/swipes
    function resetUserTimer() {
      isPaused = true;
      accumulatedTime = 0;
      if (timerProgress) timerProgress.style.width = "0%";

      if (userInteractionTimer) clearTimeout(userInteractionTimer);
      userInteractionTimer = setTimeout(() => {
        isPaused = false;
        lastTime = performance.now();
      }, 5000); // Resume autoplay after 5 seconds of inactivity
    }

    // Start auto-run loop
    requestAnimationFrame(autoPlayTick);

    // ── TOUCH SWIPE GESTURES (Parallax Drag) ──
    function getPositionX(event: TouchEvent | MouseEvent): number {
      return event.type.includes("mouse")
        ? (event as MouseEvent).clientX
        : (event as TouchEvent).touches[0].clientX;
    }

    function touchStart(event: TouchEvent | MouseEvent) {
      isDragging = true;
      startX = getPositionX(event);
      track.style.transition = "none";
      isPaused = true;
    }

    function touchMove(event: TouchEvent | MouseEvent) {
      if (!isDragging) return;
      const currentX = getPositionX(event);
      const diffX = currentX - startX;
      currentTranslate = prevTranslate + diffX;

      // Friction drag boundaries
      const maxTrans = 0;
      const minTrans = -(slides.length - 1) * slides[0].offsetWidth;
      if (currentTranslate > maxTrans) {
        currentTranslate = maxTrans + (currentTranslate - maxTrans) * 0.25;
      } else if (currentTranslate < minTrans) {
        currentTranslate = minTrans + (currentTranslate - minTrans) * 0.25;
      }

      track.style.transform = `translateX(${currentTranslate}px)`;

      // Parallax shearing effect inside active slide lantern caps
      const activeSlide = slides[activeIdx];
      const card = activeSlide.querySelector(".lantern-card") as HTMLDivElement;
      if (card) {
        const img = card.querySelector(".lantern-img") as HTMLImageElement;
        const capTop = card.querySelector(".top-cap") as HTMLDivElement;
        const capBottom = card.querySelector(".bottom-cap") as HTMLDivElement;

        if (img) img.style.transform = `scale(1.15) translateX(${diffX * 0.1}px)`;
        if (capTop) capTop.style.transform = `translateX(${diffX * 0.22}px)`;
        if (capBottom) capBottom.style.transform = `translateX(${diffX * 0.22}px)`;
      }
    }

    function touchEnd() {
      isDragging = false;
      const movedBy = currentTranslate - prevTranslate;

      // Reset card layer transformations
      const activeSlide = slides[activeIdx];
      const card = activeSlide.querySelector(".lantern-card") as HTMLDivElement;
      if (card) {
        const img = card.querySelector(".lantern-img") as HTMLImageElement;
        const capTop = card.querySelector(".top-cap") as HTMLDivElement;
        const capBottom = card.querySelector(".bottom-cap") as HTMLDivElement;
        if (img) {
          img.style.transition = "transform 0.4s ease";
          img.style.transform = "scale(1.1) translateX(0px)";
        }
        if (capTop) {
          capTop.style.transition = "transform 0.4s ease";
          capTop.style.transform = "translateX(0px)";
        }
        if (capBottom) {
          capBottom.style.transition = "transform 0.4s ease";
          capBottom.style.transform = "translateX(0px)";
        }

        setTimeout(() => {
          if (img) img.style.transition = "";
          if (capTop) capTop.style.transition = "";
          if (capBottom) capBottom.style.transition = "";
        }, 400);
      }

      // Threshold to change slide: 80px
      if (movedBy < -80 && activeIdx < slides.length - 1) {
        updateSlider(activeIdx + 1);
      } else if (movedBy > 80 && activeIdx > 0) {
        updateSlider(activeIdx - 1);
      } else {
        updateSlider(activeIdx);
      }

      resetUserTimer();
    }

    viewport.addEventListener("touchstart", touchStart, { passive: true });
    viewport.addEventListener("touchmove", touchMove, { passive: true });
    viewport.addEventListener("touchend", touchEnd);

    // Desktop mouse drag support
    viewport.addEventListener("mousedown", touchStart);
    viewport.addEventListener("mousemove", touchMove);
    viewport.addEventListener("mouseup", touchEnd);
    viewport.addEventListener("mouseleave", () => {
      if (isDragging) touchEnd();
    });

    // Handle Resize
    window.addEventListener("resize", () => {
      updateSlider(activeIdx, false);
    });

    // ── LIGHTBOX LOGIC ──
    const lightbox = document.getElementById("lanterns-lightbox") as HTMLDialogElement;
    const lightboxImg = document.getElementById("w-lightbox-image") as HTMLImageElement;
    const lightboxTitle = document.getElementById("w-lightbox-title");
    const lightboxCoords = document.getElementById("w-lightbox-coords");
    const lightboxDesc = document.getElementById("w-lightbox-desc");
    const lightboxCaptionBox = document.getElementById("w-lightbox-caption-box");
    const lightboxCaptionText = document.getElementById("w-lightbox-caption");
    const shutterBlades = document.getElementById("w-shutter-blades");

    const closeLightboxBtn = document.getElementById("w-lightbox-close");
    const lightboxPrevBtn = document.getElementById("w-lightbox-prev");
    const lightboxNextBtn = document.getElementById("w-lightbox-next");
    const backdrop = document.getElementById("w-lightbox-backdrop");
    const zoomBtns = document.querySelectorAll(
      ".lantern-zoom-btn",
    ) as NodeListOf<HTMLButtonElement>;

    if (!lightbox || !lightboxImg) return;

    let lightboxActiveIdx = 0;

    function openLightbox(idx: number) {
      if (idx < 0 || idx >= milestoneData.length) return;
      lightboxActiveIdx = idx;
      const data = milestoneData[lightboxActiveIdx];

      // Close Shutter blades animation
      if (shutterBlades) {
        shutterBlades.classList.add("shutter-closed");
      }

      setTimeout(() => {
        const slide = slides[lightboxActiveIdx];
        const img = slide.querySelector(".lantern-img") as HTMLImageElement | null;
        lightboxImg.src = img ? img.src : "";

        if (lightboxTitle) lightboxTitle.textContent = data.name;
        if (lightboxCoords) lightboxCoords.textContent = data.coords;
        if (lightboxDesc) lightboxDesc.textContent = data.desc;

        if (lightboxCaptionBox && lightboxCaptionText) {
          if (data.caption) {
            lightboxCaptionText.textContent = data.caption;
            lightboxCaptionBox.classList.remove("hidden");
          } else {
            lightboxCaptionBox.classList.add("hidden");
          }
        }

        // Open blades
        if (shutterBlades) {
          shutterBlades.classList.remove("shutter-closed");
        }
      }, 200);

      if (!lightbox.open) {
        lightbox.showModal();
        document.body.style.overflow = "hidden";
      }

      // Sync active state slide
      if (lightboxActiveIdx !== activeIdx) {
        updateSlider(lightboxActiveIdx);
      }
      resetUserTimer();
    }

    function closeLightbox() {
      lightbox.close();
      document.body.style.overflow = "";
    }

    function showLightboxNext() {
      const nextIdx = (lightboxActiveIdx + 1) % milestoneData.length;
      openLightbox(nextIdx);
    }

    function showLightboxPrev() {
      const prevIdx = (lightboxActiveIdx - 1 + milestoneData.length) % milestoneData.length;
      openLightbox(prevIdx);
    }

    zoomBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const idx = parseInt(btn.getAttribute("data-index") || "0", 10);
        openLightbox(idx);
      });
    });

    // Double clicking slide card also opens lightbox
    slides.forEach((slide, i) => {
      const card = slide.querySelector(".lantern-card");
      card?.addEventListener("dblclick", () => {
        openLightbox(i);
      });
    });

    closeLightboxBtn?.addEventListener("click", closeLightbox);
    lightboxPrevBtn?.addEventListener("click", showLightboxPrev);
    lightboxNextBtn?.addEventListener("click", showLightboxNext);
    backdrop?.addEventListener("click", closeLightbox);

    // Keyboard controls
    window.addEventListener("keydown", (e) => {
      if (!lightbox.open) return;
      if (e.key === "ArrowRight") {
        showLightboxNext();
      } else if (e.key === "ArrowLeft") {
        showLightboxPrev();
      } else if (e.key === "Escape") {
        closeLightbox();
      }
    });
  })();
</script>

