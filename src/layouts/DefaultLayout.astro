---
import { SITE } from "@config/site.ts";
import { ASSETS } from "@config/assets.ts";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const { title = SITE.title, description = SITE.description } = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a1f3e" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/images/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/images/favicon-16x16.png" />
    <title>{title}</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Nunito:wght@600;700;800&family=Open+Sans:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    {/* ── Persistent floating header ─────────────────────── */}
    <header class="site-header">
      <div class="site-header-inner">
        <div class="site-header-left">
          <img
            src={ASSETS.logo["50th"]}
            alt="Logo PALASMA"
            class="site-header-logo"
            width="58"
            height="58"
            loading="eager"
          />
        </div>
        <div class="site-header-right">
          <button
            id="music-toggle"
            type="button"
            aria-label="Toggle Background Music"
            class="site-header-music-btn"
          >
            <svg
              id="music-icon-on"
              class="site-header-music-icon hidden"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M9 18V5l12-2v13"></path>
              <circle cx="6" cy="18" r="3"></circle>
              <circle cx="18" cy="16" r="3"></circle>
            </svg>
            <svg
              id="music-icon-off"
              class="site-header-music-icon"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M9 18V5l12-2v13"></path>
              <circle cx="6" cy="18" r="3"></circle>
              <circle cx="18" cy="16" r="3"></circle>
              <line x1="1" y1="1" x2="23" y2="23"></line>
            </svg>
          </button>
        </div>
      </div>
    </header>

    <slot />

    {/* ── Audio (background music) ──────────────────────────── */}
    <audio id="bg-music" preload="auto" loop>
      <source src={ASSETS.bgMusic} type="audio/mpeg" />
    </audio>

    {/* ── Music toggle logic ─────────────────────────────────── */}
    <script>
      import { setupMusicToggle } from "@utils/splash.ts";

      const audio = document.getElementById("bg-music") as HTMLAudioElement;
      const iconOn = document.getElementById("music-icon-on") as HTMLElement;
      const iconOff = document.getElementById("music-icon-off") as HTMLElement;
      const musicToggle = document.getElementById("music-toggle") as HTMLElement;
      if (audio && iconOn && iconOff && musicToggle) {
        const music = setupMusicToggle(audio, iconOn, iconOff);
        musicToggle.addEventListener("click", () => music.toggle());
      }
    </script>
  </body>
</html>

<style>
  /* ── Persistent floating header ───────────────────────────── */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 1rem 2rem;
  }

  .site-header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
  }

  .site-header-left {
    display: flex;
    align-items: center;
  }

  .site-header-logo {
    width: 58px;
    height: 58px;
    object-fit: contain;
  }

  .site-header-right {
    display: flex;
    align-items: center;
  }

  .site-header-music-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 1px solid rgba(200, 168, 78, 0.3);
    border-radius: 50%;
    background: rgba(10, 31, 62, 0.6);
    backdrop-filter: blur(8px);
    color: var(--color-earth-cream);
    transition:
      background 0.2s,
      border-color 0.2s;
  }

  .site-header-music-btn:hover {
    background: rgba(10, 31, 62, 0.9);
    border-color: rgba(200, 168, 78, 0.5);
  }

  .site-header-music-icon {
    width: 18px;
    height: 18px;
  }

  @media (max-width: 640px) {
    .site-header-logo {
      width: 48px;
      height: 48px;
    }
  }
</style>
